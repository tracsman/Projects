@model IEnumerable<PathWeb.Models.User>
@{
    ViewData["Title"] = "Active User List";
    byte authLevel = (byte)(ViewContext.HttpContext.Items["AuthLevel"] ?? (byte)0);
}

<div class="container bg-light rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
    <p>This is a list of active users in the Pathfinders Lab Configuration database.</p>
    <p>Depending on your AuthLevel, you can add, edit, or delete users as needed with the links on this page.</p>
    <p>The AuthLevel defines the level of visibility and actions a user can take, see the chart at the bottom of this page for more information about the specific AuthLevels.</p>
    <p>If a user is set to AuthLevel == 0 or is not in the database, they will only see a Permission Error page.</p>
    <p>As the AuthLevel increases that user would see additional sections, pages, and actions appear on the site.</p>
    <p>An AuthLevel automatically has rights to all (numerically) lower AuthLevel privileges.</p>
    <p>For troubleshooting, the logged in User Name (email address) and AuthLevel, are visible in the upper right hand corner of every page on this site.</p>
    <p>For example; with AuthLevel 15, a user would see this page with "Create New", "Edit", and "Delete" options for the user list. With AuthLevel 14, the user would only be able to see the list of users and the detail view, but would not have access to create, update, or delete any user data.</p>
</div>

@if (authLevel >= 15)
{
    <p><a asp-action="Create" class="btn btn-primary">Create New User</a></p>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>User Name</th>
            <th>Name</th>
            <th>Auth Level</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Name</td>
                <td>@user.AuthLevel</td>
                <td>
                    @if (authLevel >= 15)
                    {
                        <a asp-action="Edit" asp-route-id="@user.UserId">Edit</a>
                        <span>|</span>
                    }
                    <a asp-action="Details" asp-route-id="@user.UserId">Details</a>
                    @if (authLevel >= 15)
                    {
                        <span>|</span>
                        <a asp-action="Delete" asp-route-id="@user.UserId">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

<p>User Authorization Levels are as follows:</p>
