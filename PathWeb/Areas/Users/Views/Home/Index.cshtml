    <tr><th>Read Access</th><th>Write Access</th></tr>
    <tr><td>&nbsp;&nbsp;3 - Workshop Read Only</td><td>&nbsp;&nbsp;5 - Workshop Admin</td></tr>
    <tr><td>&nbsp;&nbsp;6 - Tenant Read Only</td><td>&nbsp;&nbsp;8 - Tenant Admin</td></tr>
    <tr><td>&nbsp;&nbsp;11 - Data Admin Read Only</td><td>&nbsp;&nbsp;12 - Data Admin</td></tr>
    <tr><td>&nbsp;&nbsp;14 - Site Admin Read Only</td><td>&nbsp;&nbsp;15 - Site Admin</td></tr>
</table>

