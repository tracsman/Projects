        function updateLabVmBadge(data) {
            var vmNames = (data.requests || [])
                .filter(function (r) { return r.createdVmName; })
                .map(function (r) { return r.createdVmName; })
                .join(', ');

            _labVmRun = {
                success: data.status === 'Completed',
                status: data.status,
                createdVmNames: vmNames || null,
                submittedBy: data.submittedBy,
                submittedDate: data.startedAt,
                completedDate: data.completedAt
            };
            renderLabVmSummary();
        }

