        function renderAutomationHistory(configType) {
            var container = document.getElementById('automationHistory-' + configType);
            if (!container) return;

            var history = getAutomationHistory(configType);
            if (!history.length) {
                container.innerHTML = '<div class="text-body-secondary">No recent runs.</div>';
                return;
            }

            var latestRun = getAutomationRun(configType);
            var html = '<div class="list-group list-group-flush">';
            for (var i = 0; i < history.length; i++) {
                var run = history[i];
                var presentation = getAutomationPresentation(run.status);
                var runLabel = run.runbookName || run.jobId;
                var submitted = formatAutomationDate(run.submittedDate);
                var latestBadge = latestRun && latestRun.jobId === run.jobId ? '<span class="badge text-bg-primary-subtle text-primary-emphasis ms-2">Latest</span>' : '';
                var openDisabled = _canRunAutomation ? '' : ' disabled';
                html += '<div class="list-group-item px-0 py-2 border-0 border-bottom">'
                    + '<div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">'
                    + '<div>'
                    + '<div class="d-flex align-items-center flex-wrap gap-2">'
                    + '<span class="badge ' + presentation.badgeClass + '">' + (run.status || 'Unknown') + '</span>'
                    + '<span class="fw-semibold">' + runLabel + '</span>'
                    + latestBadge
                    + '</div>'
                    + '<div class="text-body-secondary small">' + (submitted || 'Unknown time') + ' · Job ' + run.jobId + '</div>'
                    + '</div>'
                    + '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="openAutomationModal(\'' + configType + '\', \'' + run.jobId + '\')"' + openDisabled + '>' + (run.isTerminal ? 'View' : 'Open') + '</button>'
                    + '</div>'
                    + '</div>';
            }

            container.innerHTML = html + '</div>';
        }

        function renderAllAutomationHistory() {
            renderAutomationHistory('CreateERPowerShell');
            renderAutomationHistory('CreateAzurePowerShell');
        }

        function renderAutomationRun(run, fallbackOutput) {
            if (!run) return;

            var presentation = getAutomationPresentation(run.status);
            var submittedText = run.submittedDate ? '<div><small>Submitted ' + formatAutomationDate(run.submittedDate) + ' by ' + (run.submittedBy || 'unknown') + '</small></div>' : '';
            var runbookText = run.runbookName ? 'Runbook <strong>' + run.runbookName + '</strong> — ' : '';
            setAutomationStatus('<div class="alert ' + presentation.alertClass + ' mb-0"><i class="bi ' + presentation.icon + '"></i> ' + runbookText + 'job <code>' + run.jobId + '</code> status: <strong>' + (run.status || 'Unknown') + '</strong>' + submittedText + '</div>');

            var text = run.output || fallbackOutput || '';
            if (run.exception) {
                text += (text ? '\n\n' : '') + 'EXCEPTION:\n' + run.exception;
            }
            document.getElementById('automationRunOutput').textContent = text;

            var btn = document.getElementById('automationRunBtn');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Re-run';
        }

        async function refreshAutomationSummaries() {
            try {
                var response = await fetch('@Url.Action("Latest", "Automation")?tenantGuid=' + encodeURIComponent(_tenantGuid));
                var data = await response.json();
                if (!data.success || !data.runs) return;

                for (var i = 0; i < data.runs.length; i++) {
                    setAutomationRun(data.runs[i]);
                }

                renderAllAutomationSummaries();
            } catch (err) {
                console.warn('Failed to refresh automation summaries', err);
            }
        }

        function openAutomationModal(configType, jobId) {
            var source = document.getElementById(configType);
            if (!source) {
                alert('Could not find config content for ' + configType);
                return;
            }

            resetAutomationModal();
            _automationConfigType = configType;
            _automationJobId = null;
            document.getElementById('automationModalLabel').textContent = configType === 'ServiceProviderInstructions'
                ? 'Deploy to Provider: ' + configType
                : 'Deploy to Azure: ' + configType;
            var existingRun = findAutomationRun(configType, jobId);
            document.getElementById('automationScriptEditor').value = existingRun && existingRun.preparedScript ? existingRun.preparedScript : source.value;

            if (existingRun) {
                _automationJobId = existingRun.jobId;
                renderAutomationRun(existingRun, '');
            } else {
                setAutomationStatus('<div class="alert alert-info mb-0"><i class="bi bi-info-circle-fill"></i> Review the generated PowerShell, make any edits you want, then click <strong>Run in Automation</strong>. The runbook will execute using the Automation Account managed identity.</div>');
            }

            var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('automationModal'));
            modal.show();

            if (existingRun && !existingRun.isTerminal) {
                pollAutomationJob();
            }
        }

        async function submitAutomationRun() {
            if (!_automationConfigType) return;

            var btn = document.getElementById('automationRunBtn');
            var editor = document.getElementById('automationScriptEditor');
            setSpinner(btn, 'Submitting...');

            try {
                var response = await fetch('@Url.Action("Submit", "Automation")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getToken()
                    },
                    body: JSON.stringify({
                        tenantGuid: _tenantGuid,
                        configType: _automationConfigType,
                        scriptContent: editor.value
                    })
                });

                var data = await response.json();
                if (!data.success) {
                    setAutomationStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    document.getElementById('automationRunOutput').textContent = data.output || '';
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-cloud-upload"></i> Run in Automation';
                    return;
                }

                var run = data.run;
                if (run && run.preparedScript) {
                    editor.value = run.preparedScript;
                }
                if (run) {
                    setAutomationRun(run);
                    _automationJobId = run.jobId;
                    renderAutomationRun(run, data.output || '');
                }

                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Re-run';

                pollAutomationJob();
            } catch (err) {
                setAutomationStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Submit failed: ' + err + '</div>');
                document.getElementById('automationRunOutput').textContent = String(err);
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-cloud-upload"></i> Run in Automation';
            }
        }

        async function pollAutomationJob() {
            if (!_automationJobId) return;

            try {
                var response = await fetch('@Url.Action("Status", "Automation")?jobId=' + encodeURIComponent(_automationJobId));
                var data = await response.json();

                if (!data.success) {
                    setAutomationStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Poll failed: ' + data.output + '</div>');
                    return;
                }

                if (data.run) {
                    setAutomationRun(data.run);
                    renderAutomationRun(data.run, '');
                    _automationJobId = data.run.jobId;

                    if (!data.run.isTerminal && document.getElementById('automationModal').classList.contains('show')) {
                        _automationPollTimer = setTimeout(pollAutomationJob, 3000);
                    }
                }
            } catch (err) {
                setAutomationStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Poll failed: ' + err + '</div>');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            renderAllAutomationSummaries();
            renderAllAutomationHistory();
            renderAllDeviceApplySummaries();
            renderAllEmailSendSummaries();
            refreshAutomationSummaries();

            document.getElementById('automationModal').addEventListener('hidden.bs.modal', function () {
                stopAutomationPolling();
                _automationConfigType = null;
                _automationJobId = null;
            });
        });

        function verifyOffDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Running...');

            postAction('@Url.Action("VerifyOffDevice", "DeviceActions")', configType)
            .then(function (data) {
                document.getElementById('deviceResultModalLabel').textContent = 'Verify off Device: ' + configType;
                resetModal();

                if (data.success && data.matchCount === 0) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.success) {
                    setStatus('<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Found <strong>' + data.matchCount + '</strong> reference(s) to <code>' + data.searchPattern + '</code> on ' + data.deviceName + '.</div>');
                    var outputEl = document.getElementById('deviceResultOutput');
                    outputEl.textContent = data.output;
                    outputEl.style.display = '';
                } else {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                }

                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function compareToDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Comparing...');

            postAction('@Url.Action("CompareToDevice", "DeviceActions")', configType)
            .then(function (data) {
                document.getElementById('deviceResultModalLabel').textContent = 'Compare to Device: ' + configType;
                resetModal();

                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.isMatch) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Config matches — all <strong>' + data.matchedCount + '</strong> line(s) in the stored config are present on <strong>' + data.deviceName + '</strong> (and vice versa).</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Differences found on <strong>' + data.deviceName + '</strong> — Stored: <strong>' + data.storedLineCount + '</strong> lines, Device: <strong>' + data.deviceLineCount + '</strong> lines, Matched: <strong>' + data.matchedCount + '</strong></div>');
                    var details = '';
                    if (data.missingFromDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Missing from device (' + data.missingFromDevice.length + '):</strong>' + renderPre(data.missingFromDevice, '#ff6b6b') + '</div>';
                    if (data.extraOnDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-warning"><i class="bi bi-plus-circle"></i> Extra on device (' + data.extraOnDevice.length + '):</strong>' + renderPre(data.extraOnDevice, '#ffd93d') + '</div>';
                    if (data.matchedCount > 0)
                        details += '<div class="mt-2"><a class="text-success" data-bs-toggle="collapse" href="#compareMatchedLines" role="button" aria-expanded="false"><i class="bi bi-check-circle"></i> Matched lines (' + data.matchedCount + ') — click to expand</a><div class="collapse" id="compareMatchedLines"><pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#6bff6b;">Lines matched successfully (not shown individually to keep output concise).</pre></div></div>';
                    setOutputHtml(details);
                }
                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function applyToDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Comparing...');

            postAction('@Url.Action("CompareToDevice", "DeviceActions")', configType)
            .then(function (data) {
                showModal('Apply to Device: ' + configType);
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.isMatch || data.missingFromDevice.length === 0) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Already in sync — all lines are present on <strong>' + data.deviceName + '</strong>. Nothing to apply.</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-info mb-0"><i class="bi bi-arrow-up-circle-fill"></i> Ready to apply <strong>' + data.missingFromDevice.length + '</strong> missing line(s) to <strong>' + data.deviceName + '</strong>. Review below and click <strong>Apply Now</strong> to push.</div>');
                    var details = '<div class="mt-2"><strong><i class="bi bi-arrow-up-circle"></i> Lines to apply (' + data.missingFromDevice.length + '):</strong>' + renderPre(data.missingFromDevice, '#6bff6b') + '</div>';
                    if (data.extraOnDevice.length > 0)
                        details += '<div class="mt-2"><small class="text-warning"><i class="bi bi-info-circle"></i> Note: ' + data.extraOnDevice.length + ' extra line(s) on device will not be removed (use Patch to sync fully).</small></div>';
                    setOutputHtml(details);
                    showPendingButton('applyNowBtn', configType, 'apply');
                }
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function executeApply() {
            if (!_pendingConfigType) return;
            var configType = _pendingConfigType;
            var applyBtn = document.getElementById('applyNowBtn');
            setSpinner(applyBtn, 'Applying...');

            postAction('@Url.Action("ApplyToDevice", "DeviceActions")', configType)
            .then(function (data) {
                applyBtn.classList.add('d-none');
                _pendingConfigType = null;
                if (data.applyRun) {
                    setDeviceApplyRun(data.applyRun);
                }
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Apply failed on <strong>' + configType + '</strong></div>');
                    setOutputError(data.output);
                } else if (data.applied === false) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Successfully applied <strong>' + data.appliedCount + '</strong> line(s) to <strong>' + data.deviceName + '</strong>.</div>');
                    var details = '';
                    if (data.appliedLines && data.appliedLines.length > 0)
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-check-circle"></i> Applied lines:</strong>' + renderPre(data.appliedLines, '#6bff6b') + '</div>';
                    details += renderTranscript('applyTranscript', data.transcript);
                    setOutputHtml(details);
                }
            })
            .catch(function (err) { alert('Apply request failed: ' + err); })
            .finally(function () { applyBtn.disabled = false; applyBtn.innerHTML = '<i class="bi bi-play-fill"></i> Apply Now'; });
        }

        function patchDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Comparing...');

            postAction('@Url.Action("CompareToDevice", "DeviceActions")', configType)
            .then(function (data) {
                showModal('Patch Device: ' + configType);
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.isMatch || (data.missingFromDevice.length === 0 && data.extraOnDevice.length === 0)) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Already in sync on <strong>' + data.deviceName + '</strong>. Nothing to patch.</div>');
                    setOutputHtml(null);
                } else {
                    var summary = [];
                    if (data.missingFromDevice.length > 0) summary.push('<strong>' + data.missingFromDevice.length + '</strong> line(s) to add');
                    if (data.extraOnDevice.length > 0) summary.push('<strong>' + data.extraOnDevice.length + '</strong> line(s) to remove');
                    setStatus('<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Patch will sync <strong>' + data.deviceName + '</strong>: ' + summary.join(' and ') + '. Review below and click <strong>Patch Now</strong> to execute.</div>');
                    var details = '';
                    if (data.missingFromDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-plus-circle"></i> Lines to add (' + data.missingFromDevice.length + '):</strong>' + renderPre(data.missingFromDevice, '#6bff6b') + '</div>';
                    if (data.extraOnDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Lines to remove (' + data.extraOnDevice.length + '):</strong>' + renderPre(data.extraOnDevice, '#ff6b6b') + '</div>';
                    setOutputHtml(details);
                    showPendingButton('patchNowBtn', configType, 'patch');
                }
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function executePatch() {
            if (!_pendingConfigType) return;
            var configType = _pendingConfigType;
            var patchBtn = document.getElementById('patchNowBtn');
            setSpinner(patchBtn, 'Patching...');

            postAction('@Url.Action("PatchDevice", "DeviceActions")', configType)
            .then(function (data) {
                patchBtn.classList.add('d-none');
                _pendingConfigType = null;
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Patch failed on <strong>' + configType + '</strong></div>');
                    setOutputError(data.output);
                } else if (data.patched === false) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else {
                    var summaryParts = [];
                    if (data.addedCount > 0) summaryParts.push('added <strong>' + data.addedCount + '</strong>');
                    if (data.removedCount > 0) summaryParts.push('removed <strong>' + data.removedCount + '</strong>');
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Patch complete on <strong>' + data.deviceName + '</strong> — ' + summaryParts.join(', ') + ' line(s).</div>');
                    var details = '';
                    if (data.addedLines && data.addedLines.length > 0)
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-plus-circle"></i> Added:</strong>' + renderPre(data.addedLines, '#6bff6b') + '</div>';
                    if (data.removedLines && data.removedLines.length > 0)
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Removed:</strong>' + renderPre(data.removedLines, '#ff6b6b') + '</div>';
                    details += renderTranscript('patchTranscript', data.transcript);
                    setOutputHtml(details);
                }
            })
            .catch(function (err) { alert('Patch request failed: ' + err); })
            .finally(function () { patchBtn.disabled = false; patchBtn.innerHTML = '<i class="bi bi-play-fill"></i> Patch Now'; });
        }

