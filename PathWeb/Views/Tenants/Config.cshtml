        function buildServerSelect(index, selectedServer) {
            var html = '<select class="form-select form-select-sm" id="labVmServer-' + index + '">';
            for (var i = 0; i < _labVmServers.length; i++) {
                var s = _labVmServers[i];
                var label = s.name + (s.name === _labVmDefaultServer ? ' (default)' : '');
                var selected = s.name === selectedServer ? ' selected' : '';
                html += '<option value="' + s.name + '"' + selected + '>' + label + '</option>';
            }
            return html + '</select>';
        }

        function renderLabVmTable() {
            var tbody = document.getElementById('labVmTableBody');
            var html = '';
            for (var i = 0; i < _labVmRequests.length; i++) {
                var req = _labVmRequests[i];
                html += '<tr id="labVmRow-' + req.index + '">'
                    + '<td>' + req.index + '</td>'
                    + '<td><code>' + req.os + '</code></td>'
                    + '<td>' + buildServerSelect(req.index, _labVmDefaultServer) + '</td>'
                    + '<td id="labVmRowStatus-' + req.index + '"><span class="text-body-secondary">Ready</span></td>'
                    + '</tr>';
            }
            tbody.innerHTML = html;
        }

        function renderLabVmRequestStatus(requests) {
            for (var i = 0; i < requests.length; i++) {
                var req = requests[i];
                var cell = document.getElementById('labVmRowStatus-' + req.index);
                if (!cell) continue;

                if (req.status === 'Completed') {
                    cell.innerHTML = '<span class="text-success"><i class="bi bi-check-circle-fill"></i> ' + (req.createdVmName || 'Created') + '</span>';
                } else if (req.status === 'Failed') {
                    cell.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle-fill"></i> ' + (req.message || 'Failed') + '</span>';
                } else if (req.status === 'Running') {
                    cell.innerHTML = '<span class="text-warning"><i class="bi bi-hourglass-split"></i> Running...</span>';
                } else {
                    cell.innerHTML = '<span class="text-body-secondary">' + (req.status || 'Pending') + '</span>';
                }

                // Lock the server dropdown for non-pending requests
                var select = document.getElementById('labVmServer-' + req.index);
                if (select && req.status !== 'Pending' && req.status !== 'Ready') {
                    select.disabled = true;
                }
            }
        }

        async function openLabVmModal() {
            var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('labVmModal'));

            // If there's an active or recently finished run, restore it
            if (_labVmRunId) {
                stopLabVmPolling();
                setLabVmStatus('<div class="alert alert-info mb-0"><i class="bi bi-hourglass-split"></i> Reconnecting to active run...</div>');
                modal.show();
                await resumeLabVmRun();
                return;
            }

            // Warn if VMs have already been deployed for this tenant
            if (_labVmRun && (_labVmRun.status === 'Completed' || _labVmRun.status === 'Failed')) {
                var prevStatus = _labVmRun.status === 'Completed' ? 'successfully deployed' : 'attempted (with failures)';
                if (!confirm('Lab VMs were previously ' + prevStatus + '.\n\nAre you sure you want to create VMs again?')) {
                    return;
                }
            }

            resetLabVmModal(true);
            setLabVmStatus('<div class="alert alert-info mb-0"><i class="bi bi-hourglass-split"></i> Loading VM requests...</div>');
            modal.show();

            try {
                var [reqResp, srvResp] = await Promise.all([
                    fetch('@Url.Action("Requests", "LabVm")?tenantGuid=' + encodeURIComponent(_tenantGuid)),
                    fetch('@Url.Action("Servers", "LabVm")?tenantGuid=' + encodeURIComponent(_tenantGuid))
                ]);
                var reqData = await reqResp.json();
                var srvData = await srvResp.json();

                if (!reqData.success) {
                    setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + reqData.error + '</div>');
                    document.getElementById('labVmRunBtn').disabled = true;
                    return;
                }
                if (!srvData.success) {
                    setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + srvData.error + '</div>');
                    document.getElementById('labVmRunBtn').disabled = true;
                    return;
                }

                _labVmRequests = reqData.requests;
                _labVmServers = srvData.servers;
                _labVmDefaultServer = srvData.defaultServer || (srvData.servers.length > 0 ? srvData.servers[0].name : '');

                document.getElementById('labVmModalLabel').textContent = 'Create Lab VMs: ' + reqData.tenant.tenantName;
                setLabVmStatus('<div class="alert alert-info mb-0"><i class="bi bi-info-circle-fill"></i> Review target servers and click <strong>Create VMs</strong>. Default server: <code>' + _labVmDefaultServer + '</code></div>');
                renderLabVmTable();
            } catch (err) {
                setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Failed to load: ' + err + '</div>');
                document.getElementById('labVmRunBtn').disabled = true;
            }
        }

        async function resumeLabVmRun() {
            try {
                var response = await fetch('@Url.Action("Status", "LabVm")?runId=' + encodeURIComponent(_labVmRunId));
                var data = await response.json();

                if (!data.success) {
                    setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.error + '</div>');
                    _labVmRunId = null;
                    return;
                }

                var tenantLabel = data.tenant ? data.tenant.tenantName || '' : '';
                var isRemove = _labVmRemoveMode;
                document.getElementById('labVmModalLabel').textContent = (isRemove ? 'Remove Lab VMs: ' : 'Create Lab VMs: ') + tenantLabel;

                // Rebuild table from status data (server shown as text, not dropdown)
                renderLabVmTableFromStatus(data.requests || []);
                renderLabVmRequestStatus(data.requests || []);

                var isTerminal = data.status === 'Completed' || data.status === 'Failed';
                var btn = document.getElementById('labVmRunBtn');
                var doneBtn = isRemove ? '<i class="bi bi-trash"></i> Remove All' : '<i class="bi bi-play-fill"></i> Create VMs';

                if (data.status === 'Completed') {
                    setLabVmStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + (isRemove ? 'All VMs removed successfully.' : 'All VMs created successfully.') + '</div>');
                    btn.disabled = false;
                    btn.innerHTML = doneBtn;
                    _labVmRunId = null;
                } else if (data.status === 'Failed') {
                    setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + (data.error || (isRemove ? 'One or more servers failed.' : 'One or more VM requests failed.')) + '</div>');
                    btn.disabled = false;
                    btn.innerHTML = doneBtn;
                    _labVmRunId = null;
                } else {
                    setLabVmStatus('<div class="alert alert-warning mb-0"><i class="bi bi-hourglass-split"></i> ' + (isRemove ? 'Removing VMs...' : 'VMs are being created. This may take several minutes...') + '</div>');
                    btn.disabled = true;
                    btn.innerHTML = '<i class="bi bi-hourglass-split"></i> ' + (isRemove ? 'Removing...' : 'Running...');
                    pollLabVmStatus();
                }
            } catch (err) {
                setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Failed to reconnect: ' + err + '</div>');
                _labVmRunId = null;
            }
        }

        function renderLabVmTableFromStatus(requests) {
            var tbody = document.getElementById('labVmTableBody');
            var html = '';
            for (var i = 0; i < requests.length; i++) {
                var req = requests[i];
                html += '<tr id="labVmRow-' + req.index + '">'
                    + '<td>' + req.index + '</td>'
                    + '<td><code>' + req.os + '</code></td>'
                    + '<td><code>' + (req.targetServer || '') + '</code></td>'
                    + '<td id="labVmRowStatus-' + req.index + '"><span class="text-body-secondary">Pending</span></td>'
                    + '</tr>';
            }
            tbody.innerHTML = html;
        }

        async function submitLabVmRun() {
            var btn = document.getElementById('labVmRunBtn');
            setSpinner(btn, 'Submitting...');

            var overrides = [];
            for (var i = 0; i < _labVmRequests.length; i++) {
                var req = _labVmRequests[i];
                var select = document.getElementById('labVmServer-' + req.index);
                if (select) {
                    overrides.push({ index: req.index, targetServer: select.value });
                }
            }

            try {
                var response = await fetch('@Url.Action("Submit", "LabVm")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getToken()
                    },
                    body: JSON.stringify({
                        tenantGuid: _tenantGuid,
                        vmOverrides: overrides
                    })
                });

                var data = await response.json();
                if (!data.success) {
                    setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.error + '</div>');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-play-fill"></i> Create VMs';
                    return;
                }

                _labVmRunId = data.runId;
                setLabVmStatus('<div class="alert alert-warning mb-0"><i class="bi bi-hourglass-split"></i> VMs are being created. This may take several minutes...</div>');
                btn.disabled = true;
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Running...';

                // Show running badge on the card header immediately
                _labVmRun = { status: 'Running', submittedDate: new Date().toISOString() };
                renderLabVmSummary();

                // Lock all server dropdowns
                for (var i = 0; i < _labVmRequests.length; i++) {
                    var select = document.getElementById('labVmServer-' + _labVmRequests[i].index);
                    if (select) select.disabled = true;
                }

                if (data.requests) renderLabVmRequestStatus(data.requests);
                pollLabVmStatus();
            } catch (err) {
                setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Submit failed: ' + err + '</div>');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-play-fill"></i> Create VMs';
            }
        }

        // --- Lab VM Remove ---
        var _labVmRemoveMode = false;
        var _labVmRemoveServers = [];

        async function openLabVmRemoveModal() {
            _labVmRemoveMode = true;
            _labVmRemoveServers = [];

            // If a remove run is already in progress, resume it
            if (_labVmRunId) {
                stopLabVmPolling();
                var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('labVmModal'));
                setLabVmStatus('<div class="alert alert-info mb-0"><i class="bi bi-hourglass-split"></i> Reconnecting to active run...</div>');
                modal.show();
                await resumeLabVmRun();
                return;
            }

            resetLabVmModal(true);
            var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('labVmModal'));
            document.getElementById('labVmModalLabel').textContent = 'Remove Lab VMs';
            setLabVmStatus('<div class="alert alert-info mb-0"><i class="bi bi-hourglass-split"></i> Scanning servers for tenant VMs...</div>');
            var btn = document.getElementById('labVmRunBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Scanning...';
            modal.show();

            try {
                var response = await fetch('@Url.Action("Scan", "LabVm")?tenantGuid=' + encodeURIComponent(_tenantGuid));
                var data = await response.json();

                if (!data.success) {
                    setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.error + '</div>');
                    btn.innerHTML = '<i class="bi bi-trash"></i> Remove All';
                    return;
                }

                if (data.totalVms === 0) {
                    setLabVmStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> No VMs found for this tenant on any server.</div>');
                    btn.innerHTML = '<i class="bi bi-trash"></i> Remove All';
                    document.getElementById('labVmTableBody').innerHTML = '';
                    return;
                }

                // Build the scan results table
                var tbody = document.getElementById('labVmTableBody');
                var html = '';
                var rowIndex = 0;
                for (var si = 0; si < data.servers.length; si++) {
                    var srv = data.servers[si];
                    if (srv.error) {
                        rowIndex++;
                        html += '<tr><td>' + rowIndex + '</td><td colspan="2"><code>' + srv.server + '</code></td>'
                            + '<td><span class="text-warning"><i class="bi bi-exclamation-triangle-fill"></i> Scan failed: ' + srv.error + '</span></td></tr>';
                        continue;
                    }
                    if (srv.vms.length === 0) continue;
                    _labVmRemoveServers.push(srv.server);
                    for (var vi = 0; vi < srv.vms.length; vi++) {
                        rowIndex++;
                        var vm = srv.vms[vi];
                        html += '<tr id="labVmRow-' + rowIndex + '">'
                            + '<td>' + rowIndex + '</td>'
                            + '<td><code>' + vm.name + '</code></td>'
                            + '<td><code>' + srv.server + '</code></td>'
                            + '<td id="labVmRowStatus-' + rowIndex + '"><span class="text-body-secondary">Found (State: ' + (vm.state || 'Unknown') + ')</span></td>'
                            + '</tr>';
                    }
                }
                tbody.innerHTML = html;

                document.getElementById('labVmModalLabel').textContent = 'Remove Lab VMs: ' + data.tenant.tenantName;
                setLabVmStatus('<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Found <strong>' + data.totalVms + '</strong> VM(s) on <strong>' + _labVmRemoveServers.length + '</strong> server(s). Click <strong>Remove All</strong> to delete them.</div>');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-trash"></i> Remove All';
                btn.onclick = submitLabVmRemove;
            } catch (err) {
                setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Scan failed: ' + err + '</div>');
                btn.innerHTML = '<i class="bi bi-trash"></i> Remove All';
            }
        }

        async function submitLabVmRemove() {
            if (_labVmRemoveServers.length === 0) return;

            if (!confirm('This will remove ALL tenant VMs from ' + _labVmRemoveServers.length + ' server(s):\n\n' + _labVmRemoveServers.join('\n') + '\n\nThis cannot be undone. Continue?')) {
                return;
            }

            var btn = document.getElementById('labVmRunBtn');
            setSpinner(btn, 'Removing...');

            try {
                var response = await fetch('@Url.Action("RemoveSubmit", "LabVm")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getToken()
                    },
                    body: JSON.stringify({
                        tenantGuid: _tenantGuid,
                        servers: _labVmRemoveServers
                    })
                });

                var data = await response.json();
                if (!data.success) {
                    setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.error + '</div>');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-trash"></i> Remove All';
                    return;
                }

                _labVmRunId = data.runId;
                setLabVmStatus('<div class="alert alert-warning mb-0"><i class="bi bi-hourglass-split"></i> Removing VMs. This may take a few minutes...</div>');
                btn.disabled = true;
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Removing...';

                // Rebuild table to show per-server status
                if (data.requests) {
                    var tbody = document.getElementById('labVmTableBody');
                    var html = '';
                    for (var i = 0; i < data.requests.length; i++) {
                        var req = data.requests[i];
                        html += '<tr id="labVmRow-' + req.index + '">'
                            + '<td>' + req.index + '</td>'
                            + '<td><code>Remove all</code></td>'
                            + '<td><code>' + req.targetServer + '</code></td>'
                            + '<td id="labVmRowStatus-' + req.index + '"><span class="text-body-secondary">Pending</span></td>'
                            + '</tr>';
                    }
                    tbody.innerHTML = html;
                }

                _labVmRun = { status: 'Running', submittedDate: new Date().toISOString() };
                renderLabVmSummary();
                pollLabVmStatus();
            } catch (err) {
                setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Submit failed: ' + err + '</div>');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-trash"></i> Remove All';
            }
        }

        async function pollLabVmStatus() {
            if (!_labVmRunId) return;

            var modalOpen = document.getElementById('labVmModal').classList.contains('show');

            try {
                var response = await fetch('@Url.Action("Status", "LabVm")?runId=' + encodeURIComponent(_labVmRunId));
                var data = await response.json();

                if (!data.success && data.error) {
                    if (modalOpen) setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.error + '</div>');
                    return;
                }

                // Update modal table if it's open
                if (modalOpen && data.requests) renderLabVmRequestStatus(data.requests);

                var isRemove = _labVmRemoveMode;
                if (data.status === 'Completed') {
                    if (modalOpen) {
                        setLabVmStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + (isRemove ? 'All VMs removed successfully.' : 'All VMs created successfully.') + '</div>');
                        var btn = document.getElementById('labVmRunBtn');
                        btn.disabled = false;
                        btn.innerHTML = isRemove ? '<i class="bi bi-trash"></i> Remove All' : '<i class="bi bi-play-fill"></i> Create VMs';
                    }
                    updateLabVmBadge(data);
                    _labVmRunId = null;
                } else if (data.status === 'Failed') {
                    if (modalOpen) {
                        setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + (data.error || (isRemove ? 'One or more servers failed.' : 'One or more VM requests failed.')) + '</div>');
                        var btn = document.getElementById('labVmRunBtn');
                        btn.disabled = false;
                        btn.innerHTML = isRemove ? '<i class="bi bi-trash"></i> Remove All' : '<i class="bi bi-play-fill"></i> Create VMs';
                    }
                    updateLabVmBadge(data);
                    _labVmRunId = null;
                } else {
                    // Still running — keep polling regardless of modal state
                    _labVmPollTimer = setTimeout(pollLabVmStatus, 3000);
                }
            } catch (err) {
                setLabVmStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Poll failed: ' + err + '</div>');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            renderAllAutomationSummaries();
            renderAllAutomationHistory();
            renderAllDeviceApplySummaries();
            renderAllEmailSendSummaries();
            renderLabVmSummary();
            refreshAutomationSummaries();

            document.getElementById('automationModal').addEventListener('hidden.bs.modal', function () {
                stopAutomationPolling();
                _automationConfigType = null;
                _automationJobId = null;
            });

            document.getElementById('labVmModal').addEventListener('hidden.bs.modal', function () {
                // Don't stop polling — it continues in the background for the badge.
                // Polling self-terminates when the run reaches a terminal state.
            });
        });

        function verifyOffDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Running...');

            postAction('@Url.Action("VerifyOffDevice", "DeviceActions")', configType)
            .then(function (data) {
                document.getElementById('deviceResultModalLabel').textContent = 'Verify off Device: ' + configType;
                resetModal();

                if (data.success && data.matchCount === 0) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.success) {
                    setStatus('<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Found <strong>' + data.matchCount + '</strong> reference(s) to <code>' + data.searchPattern + '</code> on ' + data.deviceName + '.</div>');
                    var outputEl = document.getElementById('deviceResultOutput');
                    outputEl.textContent = data.output;
                    outputEl.style.display = '';
                } else {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                }

                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function compareToDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Comparing...');

            postAction('@Url.Action("CompareToDevice", "DeviceActions")', configType)
            .then(function (data) {
                document.getElementById('deviceResultModalLabel').textContent = 'Compare to Device: ' + configType;
                resetModal();

                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.isMatch) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Config matches — all <strong>' + data.matchedCount + '</strong> line(s) in the stored config are present on <strong>' + data.deviceName + '</strong> (and vice versa).</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Differences found on <strong>' + data.deviceName + '</strong> — Stored: <strong>' + data.storedLineCount + '</strong> lines, Device: <strong>' + data.deviceLineCount + '</strong> lines, Matched: <strong>' + data.matchedCount + '</strong></div>');
                    var details = '';
                    if (data.missingFromDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Missing from device (' + data.missingFromDevice.length + '):</strong>' + renderPre(data.missingFromDevice, '#ff6b6b') + '</div>';
                    if (data.extraOnDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-warning"><i class="bi bi-plus-circle"></i> Extra on device (' + data.extraOnDevice.length + '):</strong>' + renderPre(data.extraOnDevice, '#ffd93d') + '</div>';
                    if (data.matchedCount > 0)
                        details += '<div class="mt-2"><a class="text-success" data-bs-toggle="collapse" href="#compareMatchedLines" role="button" aria-expanded="false"><i class="bi bi-check-circle"></i> Matched lines (' + data.matchedCount + ') — click to expand</a><div class="collapse" id="compareMatchedLines"><pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#6bff6b;">Lines matched successfully (not shown individually to keep output concise).</pre></div></div>';
                    setOutputHtml(details);
                }
                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function applyToDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Comparing...');

            postAction('@Url.Action("CompareToDevice", "DeviceActions")', configType)
            .then(function (data) {
                showModal('Apply to Device: ' + configType);
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.isMatch || data.missingFromDevice.length === 0) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Already in sync — all lines are present on <strong>' + data.deviceName + '</strong>. Nothing to apply.</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-info mb-0"><i class="bi bi-arrow-up-circle-fill"></i> Ready to apply <strong>' + data.missingFromDevice.length + '</strong> missing line(s) to <strong>' + data.deviceName + '</strong>. Review below and click <strong>Apply Now</strong> to push.</div>');
                    var details = '<div class="mt-2"><strong><i class="bi bi-arrow-up-circle"></i> Lines to apply (' + data.missingFromDevice.length + '):</strong>' + renderPre(data.missingFromDevice, '#6bff6b') + '</div>';
                    if (data.extraOnDevice.length > 0)
                        details += '<div class="mt-2"><small class="text-warning"><i class="bi bi-info-circle"></i> Note: ' + data.extraOnDevice.length + ' extra line(s) on device will not be removed (use Patch to sync fully).</small></div>';
                    setOutputHtml(details);
                    showPendingButton('applyNowBtn', configType, 'apply');
                }
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function executeApply() {
            if (!_pendingConfigType) return;
            var configType = _pendingConfigType;
            var applyBtn = document.getElementById('applyNowBtn');
            setSpinner(applyBtn, 'Applying...');

            postAction('@Url.Action("ApplyToDevice", "DeviceActions")', configType)
            .then(function (data) {
                applyBtn.classList.add('d-none');
                _pendingConfigType = null;
                if (data.applyRun) {
                    setDeviceApplyRun(data.applyRun);
                }
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Apply failed on <strong>' + configType + '</strong></div>');
                    setOutputError(data.output);
                } else if (data.applied === false) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Successfully applied <strong>' + data.appliedCount + '</strong> line(s) to <strong>' + data.deviceName + '</strong>.</div>');
                    var details = '';
                    if (data.appliedLines && data.appliedLines.length > 0)
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-check-circle"></i> Applied lines:</strong>' + renderPre(data.appliedLines, '#6bff6b') + '</div>';
                    details += renderTranscript('applyTranscript', data.transcript);
                    setOutputHtml(details);
                }
            })
            .catch(function (err) { alert('Apply request failed: ' + err); })
            .finally(function () { applyBtn.disabled = false; applyBtn.innerHTML = '<i class="bi bi-play-fill"></i> Apply Now'; });
        }

        function patchDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Comparing...');

            postAction('@Url.Action("CompareToDevice", "DeviceActions")', configType)
            .then(function (data) {
                showModal('Patch Device: ' + configType);
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else if (data.isMatch || (data.missingFromDevice.length === 0 && data.extraOnDevice.length === 0)) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Already in sync on <strong>' + data.deviceName + '</strong>. Nothing to patch.</div>');
                    setOutputHtml(null);
                } else {
                    var summary = [];
                    if (data.missingFromDevice.length > 0) summary.push('<strong>' + data.missingFromDevice.length + '</strong> line(s) to add');
                    if (data.extraOnDevice.length > 0) summary.push('<strong>' + data.extraOnDevice.length + '</strong> line(s) to remove');
                    setStatus('<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Patch will sync <strong>' + data.deviceName + '</strong>: ' + summary.join(' and ') + '. Review below and click <strong>Patch Now</strong> to execute.</div>');
                    var details = '';
                    if (data.missingFromDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-plus-circle"></i> Lines to add (' + data.missingFromDevice.length + '):</strong>' + renderPre(data.missingFromDevice, '#6bff6b') + '</div>';
                    if (data.extraOnDevice.length > 0)
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Lines to remove (' + data.extraOnDevice.length + '):</strong>' + renderPre(data.extraOnDevice, '#ff6b6b') + '</div>';
                    setOutputHtml(details);
                    showPendingButton('patchNowBtn', configType, 'patch');
                }
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function executePatch() {
            if (!_pendingConfigType) return;
            var configType = _pendingConfigType;
            var patchBtn = document.getElementById('patchNowBtn');
            setSpinner(patchBtn, 'Patching...');

            postAction('@Url.Action("PatchDevice", "DeviceActions")', configType)
            .then(function (data) {
                patchBtn.classList.add('d-none');
                _pendingConfigType = null;
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Patch failed on <strong>' + configType + '</strong></div>');
                    setOutputError(data.output);
                } else if (data.patched === false) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else {
                    var summaryParts = [];
                    if (data.addedCount > 0) summaryParts.push('added <strong>' + data.addedCount + '</strong>');
                    if (data.removedCount > 0) summaryParts.push('removed <strong>' + data.removedCount + '</strong>');
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Patch complete on <strong>' + data.deviceName + '</strong> — ' + summaryParts.join(', ') + ' line(s).</div>');
                    var details = '';
                    if (data.addedLines && data.addedLines.length > 0)
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-plus-circle"></i> Added:</strong>' + renderPre(data.addedLines, '#6bff6b') + '</div>';
                    if (data.removedLines && data.removedLines.length > 0)
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Removed:</strong>' + renderPre(data.removedLines, '#ff6b6b') + '</div>';
                    details += renderTranscript('patchTranscript', data.transcript);
                    setOutputHtml(details);
                }
            })
            .catch(function (err) { alert('Patch request failed: ' + err); })
            .finally(function () { patchBtn.disabled = false; patchBtn.innerHTML = '<i class="bi bi-play-fill"></i> Patch Now'; });
        }

        function removeFromDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Loading...');

            postAction('@Url.Action("PreviewRemoveFromDevice", "DeviceActions")', configType)
            .then(function (data) {
                showModal('Remove from Device: ' + configType);
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-exclamation-triangle-fill"></i> <strong>WARNING:</strong> This will remove <strong>' + data.removeCount + '</strong> backout line(s) from <strong>' + data.deviceName + '</strong>. This action cannot be undone. Review below and click <strong>Remove Now</strong> to execute.</div>');
                    setOutputHtml('<div class="mt-2"><strong class="text-danger"><i class="bi bi-trash"></i> Lines to remove (' + data.removeCount + '):</strong>' + renderPre(data.removeLines, '#ff6b6b') + '</div>');
                    showPendingButton('removeNowBtn', configType, 'remove');
                }
            })
            .catch(function (err) { alert('Request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        function executeRemove() {
            if (!_pendingConfigType) return;
            var configType = _pendingConfigType;
            var removeBtn = document.getElementById('removeNowBtn');
            setSpinner(removeBtn, 'Removing...');

            postAction('@Url.Action("RemoveFromDevice", "DeviceActions")', configType)
            .then(function (data) {
                removeBtn.classList.add('d-none');
                _pendingConfigType = null;
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Remove failed on <strong>' + configType + '</strong></div>');
                    setOutputError(data.output);
                } else if (data.removed === false) {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>');
                    setOutputHtml(null);
                } else {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Successfully removed <strong>' + data.removedCount + '</strong> line(s) from <strong>' + data.deviceName + '</strong>.</div>');
                    var details = '';
                    if (data.removedLines && data.removedLines.length > 0)
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-trash"></i> Removed:</strong>' + renderPre(data.removedLines, '#ff6b6b') + '</div>';
                    details += renderTranscript('removeTranscript', data.transcript);
                    setOutputHtml(details);
                }
            })
            .catch(function (err) { alert('Remove request failed: ' + err); })
            .finally(function () { removeBtn.disabled = false; removeBtn.innerHTML = '<i class="bi bi-trash"></i> Remove Now'; });
        }

        function copyToClipboard(configType, btn) {
            var textarea = document.getElementById(configType);
            if (textarea) {
                navigator.clipboard.writeText(textarea.value).then(function () {
                    var original = btn.textContent;
                    btn.textContent = '\u2714 Copied!';
                    btn.classList.replace('btn-primary', 'btn-success');
                    setTimeout(function () {
                        btn.textContent = original;
                        btn.classList.replace('btn-success', 'btn-primary');
                    }, 1500);
                });
            }
        }

        function downloadMail() {
            var mailBody = document.getElementById('eMailHTML');
            if (!mailBody) return;

            var emailTo = '@Html.Raw(Model.Contacts)';
            var emailSubject = 'Your PathLab Environment is Ready!';
            var emailCont = 'To: ' + emailTo + '\n'
                + 'Subject: ' + emailSubject + '\n'
                + 'X-Unsent: 1\n'
                + 'Content-Type: text/html\n'
                + '\n'
                + mailBody.value
                + '\n';

            var blob = new Blob([emailCont], { type: 'text/plain' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = emailSubject + '.eml';
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        function sendNotificationEmail(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            setSpinner(btn, 'Sending...');

            postAction('@Url.Action("SendNotification", "Email")', configType)
            .then(function (data) {
                if (data.emailRun) {
                    setEmailSendRun(data.emailRun);
                }

                showModal('Send Notification Email');
                if (!data.success) {
                    setStatus('<div class="alert alert-danger mb-0"><i class="bi bi-envelope-x-fill"></i> Email send failed</div>');
                    setOutputError(data.output || 'Notification email send failed.');
                } else {
                    setStatus('<div class="alert alert-success mb-0"><i class="bi bi-envelope-check-fill"></i> Notification email sent successfully.</div>');
                    var outputEl = document.getElementById('deviceResultOutput');
                    outputEl.className = 'bg-dark text-light p-3 rounded';
                    outputEl.style.background = '';
                    outputEl.style.padding = '';
                    outputEl.style.maxHeight = '400px';
                    outputEl.style.overflow = 'auto';
                    outputEl.style.whiteSpace = 'pre-wrap';
                    outputEl.textContent = data.output || 'Notification email sent.';
                    outputEl.style.display = '';
                }
            })
            .catch(function (err) { alert('Email send request failed: ' + err); })
            .finally(function () { btn.disabled = false; btn.innerHTML = originalHtml; });
        }

        document.getElementById('automationModal').addEventListener('hidden.bs.modal', function () {
            resetAutomationModal();
        });
    </script>
}
