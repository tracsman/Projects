        function renderLabVmSummary() {
            var badge = document.getElementById('labVmStatusBadge');
            var text = document.getElementById('labVmStatusText');
            if (!badge || !text) return;

            if (!_labVmRun) {
                badge.className = 'badge text-bg-secondary border-0 d-none';
                badge.textContent = '';
                text.classList.add('d-none');
                text.textContent = '';
