@model PathWeb.Models.TenantConfigViewModel
@{
    ViewData["Title"] = $"Tenant Configuration: {Model.TenantName}";
    byte authLevel = (byte)(ViewContext.HttpContext.Items["AuthLevel"] ?? (byte)0);
    object ToAutomationClientModel(PathWeb.Models.AutomationRun run) => new
    {
        configType = run.ConfigType,
        jobId = run.JobId,
        runbookName = run.RunbookName,
        status = run.Status,
        isTerminal = run.CompletedDate != null || run.Status is "Completed" or "Failed" or "Stopped" or "Suspended",
        output = run.LastOutput ?? string.Empty,
        exception = run.LastException ?? string.Empty,
        preparedScript = run.PreparedScript ?? string.Empty,
        submittedBy = run.SubmittedBy,
        submittedDate = run.SubmittedDate,
        lastStatusDate = run.LastStatusDate,
        completedDate = run.CompletedDate
    };

    var automationRuns = Model.AutomationRuns.ToDictionary(
        kvp => kvp.Key,
        kvp => ToAutomationClientModel(kvp.Value));
    var automationHistory = Model.AutomationRunHistory.ToDictionary(
        kvp => kvp.Key,
        kvp => kvp.Value.Select(ToAutomationClientModel).ToList());
    var deviceApplyRuns = Model.DeviceApplyRuns.ToDictionary(
        kvp => kvp.Key,
        kvp => new
        {
            configType = kvp.Value.ConfigType,
            actionType = kvp.Value.ActionType,
            success = kvp.Value.Success,
            status = kvp.Value.Status,
            submittedBy = kvp.Value.SubmittedBy,
            submittedDate = kvp.Value.SubmittedDate,
            output = kvp.Value.Output ?? string.Empty
        });
    var emailSendRuns = Model.EmailSendRuns.ToDictionary(
        kvp => kvp.Key,
        kvp => new
        {
            configType = kvp.Value.ConfigType,
            success = kvp.Value.Success,
            status = kvp.Value.Status,
            submittedBy = kvp.Value.SubmittedBy,
            submittedDate = kvp.Value.SubmittedDate,
            recipient = kvp.Value.Recipient ?? string.Empty,
            subject = kvp.Value.Subject ?? string.Empty,
            output = kvp.Value.Output ?? string.Empty
        });
    var automationRunsJson = System.Text.Json.JsonSerializer.Serialize(automationRuns);
    var automationHistoryJson = System.Text.Json.JsonSerializer.Serialize(automationHistory);
    var deviceApplyRunsJson = System.Text.Json.JsonSerializer.Serialize(deviceApplyRuns);
    var emailSendRunsJson = System.Text.Json.JsonSerializer.Serialize(emailSendRuns);
    var labVmRunJson = Model.LatestLabVmRun != null
        ? System.Text.Json.JsonSerializer.Serialize(new
        {
            success = Model.LatestLabVmRun.Success,
            status = Model.LatestLabVmRun.Status,
            requestCount = Model.LatestLabVmRun.RequestCount,
            createdVmNames = Model.LatestLabVmRun.CreatedVmNames,
            submittedBy = Model.LatestLabVmRun.SubmittedBy,
            submittedDate = Model.LatestLabVmRun.SubmittedDate,
            completedDate = Model.LatestLabVmRun.CompletedDate
        })
        : "null";
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
    <p>Here are all the configuration components for this tenant.</p>
    @if (Model.IsInactive)
    {
        <p class="mb-0 text-body-secondary">This tenant is inactive, so configuration is shown in read-only mode.</p>
    }
</div>

@if (!Model.Configs.Any())
{
    <div class="alert alert-warning">
        <h5>There is no config on record for this tenant.</h5>
    </div>
    <div class="d-flex gap-2">
        @if (authLevel >= 8 && !Model.IsInactive)
        {
            <a asp-action="ConfigGen" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Create Config</a>
        }
        <a asp-action="Details" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Back to Tenant</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Tenant List</a>
    </div>
}
else
{
    <div class="d-flex gap-2 mb-3">
        @if (authLevel >= 8 && !Model.IsInactive)
        {
            <a asp-action="ConfigGen" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Regenerate Config</a>
        }
        <a asp-action="Details" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Back to Tenant</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Tenant List</a>
    </div>

    var configOrder = new Dictionary<string, (int Order, string Label)>
    {
        ["CreateERPowerShell"]          = (1,  "Create ER PowerShell"),
        ["ServiceProviderInstructions"] = (2,  "Service Provider Instructions"),
        ["CreateAzurePowerShell"]       = (3,  "Create Azure PowerShell"),
        ["LabVMPowerShell"]             = (4,  "On-prem VM PowerShell"),
        ["ASH-SRX42-01"]               = (5,  "Firewall Config (ASH-SRX42-01)"),
        ["SEA-SRX42-01"]               = (5,  "Firewall Config (SEA-SRX42-01)"),
        ["ASH-ASR06X-01"]              = (6,  "Primary Router Config (ASH-ASR06X-01)"),
        ["SEA-MX03-01"]                = (6,  "Primary Router Config (SEA-MX03-01)"),
        ["ASH-ASR06X-02"]              = (7,  "Secondary Router Config (ASH-ASR06X-02)"),
        ["SEA-MX03-02"]                = (7,  "Secondary Router Config (SEA-MX03-02)"),
        ["ASH-NX9K-01"]                = (8,  "Primary Switch Config (ASH-NX9K-01)"),
        ["SEA-NX9K-01"]                = (8,  "Primary Switch Config (SEA-NX9K-01)"),
        ["ASH-NX9K-02"]                = (9,  "Secondary Switch Config (ASH-NX9K-02)"),
        ["SEA-NX9K-02"]                = (9,  "Secondary Switch Config (SEA-NX9K-02)"),
        ["BackoutConfig"]              = (10, "Backout Config"),
        ["eMailHTML"]                   = (11, "Notification eMail"),
    };

    string GetLabel(string configType) =>
        configOrder.TryGetValue(configType, out var info) ? info.Label : configType;

    int GetOrder(string configType) =>
        configOrder.TryGetValue(configType, out var info) ? info.Order : 99;

    var orderedConfigs = Model.Configs
        .Where(c => !c.ConfigType.EndsWith("-out", StringComparison.OrdinalIgnoreCase))
        .OrderBy(c => GetOrder(c.ConfigType))
        .ToList();

    @foreach (var item in orderedConfigs)
    {
        var configType = item.ConfigType;
        var label = GetLabel(configType);
        var isEmail = configType == "eMailHTML";
        var configContent = item.Config1;

        // For email preview, swap CID image references for the app-hosted logo
        if (isEmail)
        {
            configContent = configContent.Replace("cid:pathweb-logo", Url.Content("~/images/PFLogo.png"), StringComparison.OrdinalIgnoreCase);
        }

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <strong>@label</strong>
                    @if (configType == "CreateERPowerShell" || configType == "CreateAzurePowerShell" || configType == "ServiceProviderInstructions")
                    {
                        <span class="badge text-bg-secondary d-none" id="automationStatusBadge-@configType"></span>
                        <small class="text-body-secondary d-none" id="automationStatusText-@configType"></small>
                    }
                    else if (isEmail)
                    {
                        @if (Model.IsInactive)
                        {
                            <span class="badge text-bg-secondary border-0 d-none" id="emailSendStatusBadge-@configType"></span>
                        }
                        else
                        {
                            <button type="button" class="badge text-bg-secondary border-0 d-none" id="emailSendStatusBadge-@configType" onclick="openEmailSendRunModal('@configType')"></button>
                        }
                        <small class="text-body-secondary d-none" id="emailSendStatusText-@configType"></small>
                    }
                    else if (configType.Contains("SRX") || configType.Contains("MX") || configType.Contains("ASR") || configType.Contains("ISR") || configType.Contains("NX"))
                    {
                        @if (Model.IsInactive)
                        {
                            <span class="badge text-bg-secondary border-0 d-none" id="deviceApplyStatusBadge-@configType"></span>
                        }
                        else
                        {
                            <button type="button" class="badge text-bg-secondary border-0 d-none" id="deviceApplyStatusBadge-@configType" onclick="openDeviceApplyRunModal('@configType')"></button>
                        }
                        <small class="text-body-secondary d-none" id="deviceApplyStatusText-@configType"></small>
                    }
                    else if (configType == "LabVMPowerShell")
                    {
                        <span class="badge text-bg-secondary border-0 d-none" id="labVmStatusBadge"></span>
                        <small class="text-body-secondary d-none" id="labVmStatusText"></small>
                    }
                </div>
                <div class="d-flex gap-1 flex-wrap">
                    @if (!Model.IsInactive && isEmail)
                    {
                        <button class="btn btn-sm btn-outline-primary" onclick="sendNotificationEmail('@configType')"@(authLevel < 8 ? " disabled" : "")>Send Email</button>
                        <button class="btn btn-sm btn-primary" onclick="downloadMail()">Download eMail</button>
                    }
                    else if (!Model.IsInactive && (configType == "CreateERPowerShell" || configType == "CreateAzurePowerShell"))
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary d-none" id="automationReopenBtn-@configType" onclick="openAutomationModal('@configType')"@(authLevel < 8 ? " disabled" : "")>Re-open</button>
                        <div class="input-group input-group-sm" style="width: auto;">
                            <select class="form-select form-select-sm" id="action-@configType"@(authLevel < 8 ? " disabled" : "")>
                                <option value="deploy" selected>Deploy to Azure</option>
                                <option value="remove">Remove from Azure</option>
                            </select>
                            <button class="btn btn-sm btn-outline-primary" onclick="runAzureAction('@configType')" title="Run the selected action"@(authLevel < 8 ? " disabled" : "")>
                                <i class="bi bi-play-fill"></i> Run
                            </button>
                        </div>
                    }
                    else if (!Model.IsInactive && configType == "LabVMPowerShell")
                    {
                        <div class="input-group input-group-sm" style="width: auto;">
                            <select class="form-select form-select-sm" id="action-@configType"@(authLevel < 8 ? " disabled" : "")>
                                <option value="create" selected>Create Lab VMs</option>
                                <option value="remove">Remove Lab VMs</option>
                            </select>
                            <button class="btn btn-sm btn-outline-primary" onclick="runLabVmAction()" title="Run the selected action"@(authLevel < 8 ? " disabled" : "")>
                                <i class="bi bi-play-fill"></i> Run
                            </button>
                        </div>
                    }
                    else if (!Model.IsInactive && configType == "ServiceProviderInstructions")
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary d-none" id="automationReopenBtn-@configType" onclick="openAutomationModal('@configType')"@(authLevel < 8 ? " disabled" : "")>Re-open</button>
                        <div class="input-group input-group-sm" style="width: auto;">
                            <select class="form-select form-select-sm" id="action-@configType"@(authLevel < 8 ? " disabled" : "")>
                                <option value="provision" selected>Provision at Provider</option>
                                <option value="deprovision">Deprovision at Provider</option>
                            </select>
                            <button class="btn btn-sm btn-outline-primary" onclick="runProviderAction('@configType')" title="Run the selected action"@(authLevel < 8 ? " disabled" : "")>
                                <i class="bi bi-play-fill"></i> Run
                            </button>
                        </div>
                    }
                    else if (!Model.IsInactive && (configType.Contains("SRX") || configType.Contains("MX") || configType.Contains("ASR") || configType.Contains("ISR") || configType.Contains("NX")))
                    {
                        <div class="input-group input-group-sm" style="width: auto;">
                            <select class="form-select form-select-sm" id="action-@configType"@(authLevel < 8 ? " disabled" : "")>
                                <option value="apply" selected>Apply to Device</option>
                                <option value="compare">Compare to Device</option>
                                <option value="patch">Patch Device</option>
                                <option value="remove">Remove from Device</option>
                                <option value="verify">Verify off Device</option>
                            </select>
                            <button class="btn btn-sm btn-outline-primary" onclick="runDeviceAction('@configType')" title="Run the selected action on the device"@(authLevel < 8 ? " disabled" : "")>
                                <i class="bi bi-play-fill"></i> Run
                            </button>
                        </div>
                    }
                    <button class="btn btn-sm btn-primary" onclick="copyToClipboard('@configType', this)">Copy to Clipboard</button>
                </div>
            </div>
            <textarea readonly rows="10" class="form-control border-0 rounded-0" id="@configType">@configContent</textarea>
            @if (!Model.IsInactive && (configType == "CreateERPowerShell" || configType == "CreateAzurePowerShell" || configType == "ServiceProviderInstructions"))
            {
                <div class="border-top px-3 py-2 bg-body-tertiary">
                    <button class="btn btn-sm btn-link text-decoration-none px-0" type="button" data-bs-toggle="collapse" data-bs-target="#automationHistoryCollapse-@configType" aria-expanded="false" aria-controls="automationHistoryCollapse-@configType">
                        <i class="bi bi-clock-history"></i> Recent runs
                    </button>
                    <div class="collapse mt-2" id="automationHistoryCollapse-@configType">
                        <div id="automationHistory-@configType" class="small"></div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="d-flex gap-2 mt-3">
        @if (authLevel >= 8 && !Model.IsInactive)
        {
            <a asp-action="ConfigGen" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Regenerate Config</a>
        }
        <a asp-action="Details" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Back to Tenant</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Tenant List</a>
    </div>
}

@Html.AntiForgeryToken()

<div class="modal fade" id="infoModal" tabindex="-1" aria-labelledby="infoModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="infoModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="infoModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deviceResultModal"
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deviceResultModalLabel">Device Action Result</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="deviceResultStatus" class="mb-2"></div>
                <pre id="deviceResultOutput" class="bg-dark text-light p-3 rounded" style="max-height:400px; overflow:auto; white-space:pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning d-none" id="applyNowBtn" onclick="executeApply()">
                    <i class="bi bi-play-fill"></i> Apply Now
                </button>
                <button type="button" class="btn btn-danger d-none" id="patchNowBtn" onclick="executePatch()">
                    <i class="bi bi-play-fill"></i> Patch Now
                </button>
                <button type="button" class="btn btn-danger d-none" id="removeNowBtn" onclick="executeRemove()">
                    <i class="bi bi-trash"></i> Remove Now
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="automationModal" tabindex="-1" aria-labelledby="automationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="automationModalLabel">Deploy to Azure</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="automationRunStatus" class="mb-2"></div>
                <label for="automationScriptEditor" class="form-label"><strong>Runbook script (editable before submission)</strong></label>
                <textarea id="automationScriptEditor" class="form-control font-monospace mb-3" rows="16" spellcheck="false"></textarea>
                <label for="automationRunOutput" class="form-label"><strong>Runbook output</strong></label>
                <pre id="automationRunOutput" class="bg-dark text-light p-3 rounded mb-0" style="max-height:350px; overflow:auto; white-space:pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="automationRunBtn" onclick="submitAutomationRun()">
                    <i class="bi bi-cloud-upload"></i> Run in Automation
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="labVmModal" tabindex="-1" aria-labelledby="labVmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="labVmModalLabel">Create Lab VMs</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="labVmStatus" class="mb-2"></div>
                <table class="table table-sm mb-0" id="labVmTable">
                    <thead>
                        <tr>
                            <th style="width:50px">#</th>
                            <th style="width:130px">OS</th>
                            <th>Target Server</th>
                            <th style="width:200px">Status</th>
                        </tr>
                    </thead>
                    <tbody id="labVmTableBody"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="labVmRunBtn" onclick="submitLabVmRun()">
                    <i class="bi bi-play-fill"></i> Create VMs
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showInfoModal(title, bodyHtml) {
            document.getElementById('infoModalLabel').textContent = title;
            document.getElementById('infoModalBody').innerHTML = bodyHtml;
            new bootstrap.Modal(document.getElementById('infoModal')).show();
        }

        function runDeviceAction(configType) {
            var action = document.getElementById('action-' + configType).value;
            if (action === 'verify') {
                verifyOffDevice(configType);
            } else if (action === 'compare') {
                compareToDevice(configType);
            } else if (action === 'apply') {
                applyToDevice(configType);
            } else if (action === 'patch') {
                patchDevice(configType);
            } else if (action === 'remove') {
                removeFromDevice(configType);
            } else {
                alert('Action: ' + action + '\nDevice: ' + configType + '\n\nThis feature is coming soon!');
            }
        }

        function runAzureAction(configType) {
            var action = document.getElementById('action-' + configType).value;
            if (action === 'deploy') {
                openAutomationModal(configType);
            } else if (action === 'remove') {
                if (configType === 'CreateERPowerShell') {
                    showInfoModal('Remove from Azure',
                        'Removal of the ExpressRoute circuit for this tenant should be done via the <strong>Remove from Azure</strong> action on the <strong>Create Azure PowerShell</strong> card.');
                } else if (configType === 'CreateAzurePowerShell') {
                    openRemoveFromAzureModal(configType);
                }
            }
        }

        async function openRemoveFromAzureModal(configType) {
            try {
                var response = await fetch('@Url.Action("BackoutScript", "Automation")?tenantGuid=' + encodeURIComponent(_tenantGuid) + '&configType=' + encodeURIComponent(configType));
                var data = await response.json();
                if (!data.success) {
                    showInfoModal('Remove from Azure', '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.error + '</div>');
                    return;
                }
                openAutomationModal(configType, null, 'remove', data.script);
            } catch (err) {
                showInfoModal('Remove from Azure', '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Failed to load backout script: ' + err + '</div>');
            }
        }

        function runProviderAction(configType) {
            var action = document.getElementById('action-' + configType).value;
            if (action === 'provision') {
                openAutomationModal(configType);
            } else if (action === 'deprovision') {
                openAutomationModal(configType, null, 'deprovision');
            }
        }

        function runLabVmAction() {
            var action = document.getElementById('action-LabVMPowerShell').value;
            if (action === 'create') {
                openLabVmModal();
            } else if (action === 'remove') {
                openLabVmRemoveModal();
            }
        }

        var _pendingAction = null;
        var _pendingConfigType = null;
        var _automationConfigType = null;
        var _automationJobId = null;
        var _automationPollTimer = null;
        var _automationRuns = @Html.Raw(automationRunsJson);
        var _automationHistory = @Html.Raw(automationHistoryJson);
        var _deviceApplyRuns = @Html.Raw(deviceApplyRunsJson);
        var _emailSendRuns = @Html.Raw(emailSendRunsJson);
        var _labVmRun = @Html.Raw(labVmRunJson);
        var _canRunAutomation = @(authLevel >= 8 ? "true" : "false");

        function resetModal() {
            var outputEl = document.getElementById('deviceResultOutput');
            outputEl.className = 'bg-dark text-light p-3 rounded';
            outputEl.style.background = '';
            outputEl.style.padding = '';
            outputEl.style.maxHeight = '400px';
            document.getElementById('applyNowBtn').classList.add('d-none');
            document.getElementById('patchNowBtn').classList.add('d-none');
            document.getElementById('removeNowBtn').classList.add('d-none');
            _pendingAction = null;
            _pendingConfigType = null;
        }

        // Shared helpers
        var _tenantGuid = '@Model.TenantGuid';

        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function postAction(url, configType) {
            return fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getToken()
                },
                body: 'tenantGuid=' + encodeURIComponent(_tenantGuid) + '&configType=' + encodeURIComponent(configType)
            }).then(function (r) { return r.json(); });
        }

        function setSpinner(btn, text) {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> ' + text;
        }

        function showModal(title) {
            document.getElementById('deviceResultModalLabel').textContent = title;
            resetModal();
            new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
        }

        function setStatus(html) {
            document.getElementById('deviceResultStatus').innerHTML = html;
        }

        function setOutputHtml(details) {
            var outputEl = document.getElementById('deviceResultOutput');
            if (!details) {
                outputEl.textContent = '';
                outputEl.style.display = 'none';
                return;
            }
            outputEl.innerHTML = details;
            outputEl.style.display = '';
            outputEl.classList.remove('bg-dark', 'text-light');
            outputEl.style.background = 'none';
            outputEl.style.padding = '0';
        }

        function setOutputError(text) {
            var outputEl = document.getElementById('deviceResultOutput');
            outputEl.className = 'p-2 rounded mt-1';
            outputEl.style.background = '#1a1a2e';
            outputEl.style.color = '#ff6b6b';
            outputEl.style.maxHeight = '400px';
            outputEl.style.overflow = 'auto';
            outputEl.style.whiteSpace = 'pre-wrap';
            outputEl.textContent = text;
            outputEl.style.display = '';
        }

        function renderPre(lines, color) {
            var html = '<pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:' + color + ';">';
            for (var i = 0; i < lines.length; i++) html += lines[i] + '\n';
            return html + '</pre>';
        }

        function renderTranscript(id, transcript) {
            if (!transcript) return '';
            return '<div class="mt-2"><a class="text-info" data-bs-toggle="collapse" href="#' + id + '" role="button" aria-expanded="false"><i class="bi bi-terminal"></i> Session transcript — click to expand</a>'
                + '<div class="collapse" id="' + id + '"><pre class="p-2 rounded mt-1 mb-0" style="max-height:250px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#b0b0b0;">'
                + transcript.replace(/</g, '&lt;').replace(/>/g, '&gt;')
                + '</pre></div></div>';
        }

        function showPendingButton(btnId, configType, action) {
            _pendingAction = action;
            _pendingConfigType = configType;
            document.getElementById(btnId).classList.remove('d-none');
        }

        function stopAutomationPolling() {
            if (_automationPollTimer) {
                clearTimeout(_automationPollTimer);
                _automationPollTimer = null;
            }
        }

        function resetAutomationModal() {
            stopAutomationPolling();
            document.getElementById('automationRunStatus').innerHTML = '';
            document.getElementById('automationRunOutput').textContent = '';

            var btn = document.getElementById('automationRunBtn');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-cloud-upload"></i> Run in Automation';
        }

        function setAutomationStatus(html) {
            document.getElementById('automationRunStatus').innerHTML = html;
        }

        function getAutomationRun(configType) {
            return _automationRuns[configType] || null;
        }

        function getDeviceApplyRun(configType) {
            return _deviceApplyRuns[configType] || null;
        }

        function getEmailSendRun(configType) {
            return _emailSendRuns[configType] || null;
        }

        function getAutomationHistory(configType) {
            return _automationHistory[configType] || [];
        }

        function compareAutomationRuns(left, right) {
            var leftDate = left && left.submittedDate ? new Date(left.submittedDate).getTime() : 0;
            var rightDate = right && right.submittedDate ? new Date(right.submittedDate).getTime() : 0;
            return rightDate - leftDate;
        }

        function findAutomationRun(configType, jobId) {
            if (!jobId) return getAutomationRun(configType);

            var history = getAutomationHistory(configType);
            for (var i = 0; i < history.length; i++) {
                if (history[i].jobId === jobId) {
                    return history[i];
                }
            }

            var latestRun = getAutomationRun(configType);
            return latestRun && latestRun.jobId === jobId ? latestRun : null;
        }

        function setAutomationRun(run) {
            if (!run || !run.configType) return;

            _automationRuns[run.configType] = run;
            var history = getAutomationHistory(run.configType).slice();
            var existingIndex = -1;
            for (var i = 0; i < history.length; i++) {
                if (history[i].jobId === run.jobId) {
                    existingIndex = i;
                    break;
                }
            }

            if (existingIndex >= 0) {
                history[existingIndex] = run;
            } else {
                history.unshift(run);
            }

            history.sort(compareAutomationRuns);
            _automationHistory[run.configType] = history.slice(0, 5);
            renderAutomationSummary(run.configType);
            renderAutomationHistory(run.configType);
        }

        function setDeviceApplyRun(run) {
            if (!run || !run.configType) return;
            _deviceApplyRuns[run.configType] = run;
            renderDeviceApplySummary(run.configType);
        }

        function setEmailSendRun(run) {
            if (!run || !run.configType) return;
            _emailSendRuns[run.configType] = run;
            renderEmailSendSummary(run.configType);
        }

        function getAutomationPresentation(status) {
            if (status === 'Completed') return { badgeClass: 'text-bg-success', alertClass: 'alert-success', icon: 'bi-check-circle-fill' };
            if (status === 'Failed' || status === 'Stopped' || status === 'Suspended') return { badgeClass: 'text-bg-danger', alertClass: 'alert-danger', icon: 'bi-x-circle-fill' };
            if (status === 'Running' || status === 'New' || status === 'Queued') return { badgeClass: 'text-bg-warning', alertClass: 'alert-warning', icon: 'bi-hourglass-split' };
            return { badgeClass: 'text-bg-secondary', alertClass: 'alert-info', icon: 'bi-info-circle-fill' };
        }

        function formatAutomationDate(value) {
            if (!value) return '';
            var date = new Date(value);
            if (isNaN(date.getTime())) return '';
            return date.toLocaleString();
        }

        function renderAutomationSummary(configType) {
            var badge = document.getElementById('automationStatusBadge-' + configType);
            var text = document.getElementById('automationStatusText-' + configType);
            var reopenBtn = document.getElementById('automationReopenBtn-' + configType);
            if (!badge || !text || !reopenBtn) return;

            var run = getAutomationRun(configType);
            if (!run) {
                badge.className = 'badge text-bg-secondary d-none';
                badge.textContent = '';
                text.classList.add('d-none');
                text.textContent = '';
                reopenBtn.classList.add('d-none');
                reopenBtn.textContent = 'Re-open';
                return;
            }

            var presentation = getAutomationPresentation(run.status);
            badge.className = 'badge ' + presentation.badgeClass;
            badge.textContent = run.status || 'Unknown';

            var summaryText = '';
            if (run.completedDate) {
                summaryText = 'Completed ' + formatAutomationDate(run.completedDate);
            } else if (run.lastStatusDate) {
                summaryText = 'Last checked ' + formatAutomationDate(run.lastStatusDate);
            } else if (run.submittedDate) {
                summaryText = 'Submitted ' + formatAutomationDate(run.submittedDate);
            }

            if (summaryText) {
                text.textContent = summaryText;
                text.classList.remove('d-none');
            } else {
                text.textContent = '';
                text.classList.add('d-none');
            }

            reopenBtn.textContent = run.isTerminal ? 'View run' : 'Re-open';
            reopenBtn.classList.remove('d-none');
        }

        function renderAllAutomationSummaries() {
            renderAutomationSummary('CreateERPowerShell');
            renderAutomationSummary('CreateAzurePowerShell');
        }

        function renderDeviceApplySummary(configType) {
            var badge = document.getElementById('deviceApplyStatusBadge-' + configType);
            var text = document.getElementById('deviceApplyStatusText-' + configType);
