@model IEnumerable<PathWeb.Models.Config>
@{
    ViewData["Title"] = $"Tenant Configuration: {ViewData["TenantName"]}";
    byte authLevel = (byte)(ViewContext.HttpContext.Items["AuthLevel"] ?? (byte)0);
    var contacts = ViewData["Contacts"]?.ToString() ?? "";
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
    <p>Here are all the configuration components for this tenant.</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        <h5>There is no config on record for this tenant.</h5>
    </div>
    <div class="d-flex gap-2">
        @if (authLevel >= 8)
        {
            <a asp-action="ConfigGen" asp-route-id="@ViewData["TenantGuid"]" class="btn btn-primary">Create Config</a>
        }
        <a asp-action="Details" asp-route-id="@ViewData["TenantGuid"]" class="btn btn-primary">Back to Tenant</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Tenant List</a>
    </div>
}
else
{
    <div class="d-flex gap-2 mb-3">
        @if (authLevel >= 8)
        {
            <a asp-action="ConfigGen" asp-route-id="@ViewData["TenantGuid"]" class="btn btn-primary">Regenerate Config</a>
        }
        <a asp-action="Details" asp-route-id="@ViewData["TenantGuid"]" class="btn btn-primary">Back to Tenant</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Tenant List</a>
    </div>

    var configOrder = new Dictionary<string, (int Order, string Label)>
    {
        ["CreateERPowerShell"]          = (1,  "Create ER PowerShell"),
        ["ServiceProviderInstructions"] = (2,  "Service Provider Instructions"),
        ["CreateAzurePowerShell"]       = (3,  "Create Azure PowerShell"),
        ["LabVMPowerShell"]             = (4,  "On-prem VM PowerShell"),
        ["ASH-SRX42-01"]               = (5,  "Firewall Config (ASH-SRX42-01)"),
        ["SEA-SRX42-01"]               = (5,  "Firewall Config (SEA-SRX42-01)"),
        ["ASH-ASR06X-01"]              = (6,  "Primary Router Config (ASH-ASR06X-01)"),
        ["SEA-MX03-01"]                = (6,  "Primary Router Config (SEA-MX03-01)"),
        ["ASH-ASR06X-02"]              = (7,  "Secondary Router Config (ASH-ASR06X-02)"),
        ["SEA-MX03-02"]                = (7,  "Secondary Router Config (SEA-MX03-02)"),
        ["ASH-NX9K-01"]                = (8,  "Primary Switch Config (ASH-NX9K-01)"),
        ["SEA-NX9K-01"]                = (8,  "Primary Switch Config (SEA-NX9K-01)"),
        ["ASH-NX9K-02"]                = (9,  "Secondary Switch Config (ASH-NX9K-02)"),
        ["SEA-NX9K-02"]                = (9,  "Secondary Switch Config (SEA-NX9K-02)"),
        ["BackoutConfig"]              = (10, "Backout Config"),
        ["eMailHTML"]                   = (11, "Notification eMail"),
    };

    string GetLabel(string configType) =>
        configOrder.TryGetValue(configType, out var info) ? info.Label : configType;

    int GetOrder(string configType) =>
        configOrder.TryGetValue(configType, out var info) ? info.Order : 99;

    var orderedConfigs = Model.OrderBy(c => GetOrder(c.ConfigType)).ToList();

    @foreach (var item in orderedConfigs)
    {
        var configType = item.ConfigType;
        var label = GetLabel(configType);
        var isEmail = configType == "eMailHTML";
        var configContent = item.Config1;

        // For email, swap embedded image references for SharePoint links
        if (isEmail)
        {
            configContent = configContent.Replace("cid:", "https://microsoft.sharepoint.com/teams/Pathfinders/SiteAssets/");
        }

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@label</strong>
                <div class="d-flex gap-1">
                    @if (isEmail)
                    {
                        <button class="btn btn-sm btn-primary" onclick="downloadMail()">Download eMail</button>
                    }
                    else if (configType == "CreateERPowerShell" || configType == "CreateAzurePowerShell")
                    {
                        <button disabled class="btn btn-sm btn-outline-primary">Deploy to Azure</button>
                    }
                    else if (configType == "LabVMPowerShell")
                    {
                        <button disabled class="btn btn-sm btn-outline-primary">Create Lab VMs</button>
                    }
                    else if (configType == "ServiceProviderInstructions")
                    {
                        <button disabled class="btn btn-sm btn-outline-primary">Deploy to Provider</button>
                    }
                    else if (configType.Contains("SRX") || configType.Contains("MX") || configType.Contains("ASR") || configType.Contains("ISR") || configType.Contains("NX"))
                    {
                        <div class="input-group input-group-sm" style="width: auto;">
                            <select class="form-select form-select-sm" id="action-@configType"@(authLevel < 8 ? " disabled" : "")>
                                <option value="apply">Apply to Device</option>
                                <option value="compare">Compare to Device</option>
                                <option value="patch">Patch Device</option>
                                <option value="remove">Remove from Device</option>
                                <option value="verify" selected>Verify off Device</option>
                            </select>
                            <button class="btn btn-sm btn-outline-primary" onclick="runDeviceAction('@configType')" title="Run the selected action on the device"@(authLevel < 8 ? " disabled" : "")>
                                <i class="bi bi-play-fill"></i> Run
                            </button>
                        </div>
                    }
                    else if (configType == "BackoutConfig")
                    {
                        <button disabled class="btn btn-sm btn-outline-primary">TBD</button>
                    }
                    <button class="btn btn-sm btn-primary" onclick="copyToClipboard('@configType', this)">Copy to Clipboard</button>
                </div>
            </div>
            <textarea readonly rows="10" class="form-control border-0 rounded-0" id="@configType">@configContent</textarea>
        </div>
    }

    <div class="d-flex gap-2 mt-3">
        @if (authLevel >= 8)
        {
            <a asp-action="ConfigGen" asp-route-id="@ViewData["TenantGuid"]" class="btn btn-primary">Regenerate Config</a>
        }
        <a asp-action="Details" asp-route-id="@ViewData["TenantGuid"]" class="btn btn-primary">Back to Tenant</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Tenant List</a>
    </div>
}

@Html.AntiForgeryToken()

<div class="modal fade" id="deviceResultModal" tabindex="-1" aria-labelledby="deviceResultModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deviceResultModalLabel">Device Action Result</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="deviceResultStatus" class="mb-2"></div>
                <pre id="deviceResultOutput" class="bg-dark text-light p-3 rounded" style="max-height:400px; overflow:auto; white-space:pre-wrap;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning d-none" id="applyNowBtn" onclick="executeApply()">
                    <i class="bi bi-play-fill"></i> Apply Now
                </button>
                <button type="button" class="btn btn-danger d-none" id="patchNowBtn" onclick="executePatch()">
                    <i class="bi bi-play-fill"></i> Patch Now
                </button>
                <button type="button" class="btn btn-danger d-none" id="removeNowBtn" onclick="executeRemove()">
                    <i class="bi bi-trash"></i> Remove Now
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function runDeviceAction(configType) {
            var action = document.getElementById('action-' + configType).value;
            if (action === 'verify') {
                verifyOffDevice(configType);
            } else if (action === 'compare') {
                compareToDevice(configType);
            } else if (action === 'apply') {
                applyToDevice(configType);
            } else if (action === 'patch') {
                patchDevice(configType);
            } else if (action === 'remove') {
                removeFromDevice(configType);
            } else {
                alert('Action: ' + action + '\nDevice: ' + configType + '\n\nThis feature is coming soon!');
            }
        }

        var _pendingApplyConfigType = null;
        var _pendingPatchConfigType = null;
        var _pendingRemoveConfigType = null;

        function resetModal() {
            var outputEl = document.getElementById('deviceResultOutput');
            outputEl.className = 'bg-dark text-light p-3 rounded';
            outputEl.style.background = '';
            outputEl.style.padding = '';
            outputEl.style.maxHeight = '400px';
            document.getElementById('applyNowBtn').classList.add('d-none');
            document.getElementById('patchNowBtn').classList.add('d-none');
            document.getElementById('removeNowBtn').classList.add('d-none');
            _pendingApplyConfigType = null;
            _pendingPatchConfigType = null;
            _pendingRemoveConfigType = null;
        }

        function verifyOffDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Running...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("VerifyOffDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');
                var titleEl = document.getElementById('deviceResultModalLabel');

                titleEl.textContent = 'Verify off Device: ' + configType;
                resetModal();

                if (data.success && data.matchCount === 0) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else if (data.success) {
                    statusEl.innerHTML = '<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Found <strong>' + data.matchCount + '</strong> reference(s) to <code>' + data.searchPattern + '</code> on ' + data.deviceName + '.</div>';
                    outputEl.textContent = data.output;
                    outputEl.style.display = '';
                } else {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                }

                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) {
                alert('Request failed: ' + err);
            })
            .finally(function () {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        function compareToDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Comparing...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("CompareToDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');
                var titleEl = document.getElementById('deviceResultModalLabel');

                titleEl.textContent = 'Compare to Device: ' + configType;

                if (!data.success) {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else if (data.isMatch) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Config matches — all <strong>' + data.matchedCount + '</strong> line(s) in the stored config are present on <strong>' + data.deviceName + '</strong> (and vice versa).</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else {
                    var html = '<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Differences found on <strong>' + data.deviceName + '</strong> — '
                        + 'Stored: <strong>' + data.storedLineCount + '</strong> lines, '
                        + 'Device: <strong>' + data.deviceLineCount + '</strong> lines, '
                        + 'Matched: <strong>' + data.matchedCount + '</strong></div>';
                    statusEl.innerHTML = html;

                    var details = '';
                    if (data.missingFromDevice.length > 0) {
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Missing from device (' + data.missingFromDevice.length + '):</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#ff6b6b;">';
                        for (var i = 0; i < data.missingFromDevice.length; i++) {
                            details += data.missingFromDevice[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    if (data.extraOnDevice.length > 0) {
                        details += '<div class="mt-2"><strong class="text-warning"><i class="bi bi-plus-circle"></i> Extra on device (' + data.extraOnDevice.length + '):</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#ffd93d;">';
                        for (var i = 0; i < data.extraOnDevice.length; i++) {
                            details += data.extraOnDevice[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    if (data.matchedCount > 0) {
                        details += '<div class="mt-2"><a class="text-success" data-bs-toggle="collapse" href="#compareMatchedLines" role="button" aria-expanded="false"><i class="bi bi-check-circle"></i> Matched lines (' + data.matchedCount + ') — click to expand</a>';
                        details += '<div class="collapse" id="compareMatchedLines"><pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#6bff6b;">Lines matched successfully (not shown individually to keep output concise).</pre></div></div>';
                    }
                    outputEl.innerHTML = details;
                    outputEl.style.display = '';
                    outputEl.classList.remove('bg-dark', 'text-light');
                    outputEl.style.background = 'none';
                    outputEl.style.padding = '0';
                }

                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) {
                alert('Request failed: ' + err);
            })
            .finally(function () {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        function applyToDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Comparing...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("CompareToDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');
                var titleEl = document.getElementById('deviceResultModalLabel');

                titleEl.textContent = 'Apply to Device: ' + configType;
                resetModal();

                if (!data.success) {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else if (data.isMatch) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Already in sync — all <strong>' + data.matchedCount + '</strong> line(s) are present on <strong>' + data.deviceName + '</strong>. Nothing to apply.</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else if (data.missingFromDevice.length === 0) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> No missing lines — stored config is fully applied on <strong>' + data.deviceName + '</strong>.</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else {
                    statusEl.innerHTML = '<div class="alert alert-info mb-0"><i class="bi bi-arrow-up-circle-fill"></i> Ready to apply <strong>' + data.missingFromDevice.length + '</strong> missing line(s) to <strong>' + data.deviceName + '</strong>. Review below and click <strong>Apply Now</strong> to push.</div>';

                    var details = '<div class="mt-2"><strong><i class="bi bi-arrow-up-circle"></i> Lines to apply (' + data.missingFromDevice.length + '):</strong>';
                    details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:250px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#6bff6b;">';
                    for (var i = 0; i < data.missingFromDevice.length; i++) {
                        details += data.missingFromDevice[i] + '\n';
                    }
                    details += '</pre></div>';

                    if (data.extraOnDevice.length > 0) {
                        details += '<div class="mt-2"><small class="text-warning"><i class="bi bi-info-circle"></i> Note: ' + data.extraOnDevice.length + ' extra line(s) on device will not be removed (use Patch to sync fully).</small></div>';
                    }

                    outputEl.innerHTML = details;
                    outputEl.style.display = '';
                    outputEl.classList.remove('bg-dark', 'text-light');
                    outputEl.style.background = 'none';
                    outputEl.style.padding = '0';

                    _pendingApplyConfigType = configType;
                    document.getElementById('applyNowBtn').classList.remove('d-none');
                }

                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) {
                alert('Request failed: ' + err);
            })
            .finally(function () {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        function executeApply() {
            var configType = _pendingApplyConfigType;
            if (!configType) return;

            var applyBtn = document.getElementById('applyNowBtn');
            applyBtn.disabled = true;
            applyBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Applying...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("ApplyToDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');

                applyBtn.classList.add('d-none');
                _pendingApplyConfigType = null;

                if (!data.success) {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Apply failed on <strong>' + configType + '</strong></div>';
                    outputEl.className = 'p-2 rounded mt-1';
                    outputEl.style.background = '#1a1a2e';
                    outputEl.style.color = '#ff6b6b';
                    outputEl.style.maxHeight = '400px';
                    outputEl.style.overflow = 'auto';
                    outputEl.style.whiteSpace = 'pre-wrap';
                    outputEl.textContent = data.output;
                    outputEl.style.display = '';
                } else if (data.applied === false) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Successfully applied <strong>' + data.appliedCount + '</strong> line(s) to <strong>' + data.deviceName + '</strong>.</div>';

                    var details = '';
                    if (data.appliedLines && data.appliedLines.length > 0) {
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-check-circle"></i> Applied lines:</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#6bff6b;">';
                        for (var i = 0; i < data.appliedLines.length; i++) {
                            details += data.appliedLines[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    if (data.transcript) {
                        details += '<div class="mt-2"><a class="text-info" data-bs-toggle="collapse" href="#applyTranscript" role="button" aria-expanded="false"><i class="bi bi-terminal"></i> Session transcript — click to expand</a>';
                        details += '<div class="collapse" id="applyTranscript"><pre class="p-2 rounded mt-1 mb-0" style="max-height:250px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#b0b0b0;">';
                        details += data.transcript.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                        details += '</pre></div></div>';
                    }
                    outputEl.innerHTML = details;
                    outputEl.style.display = details ? '' : 'none';
                    outputEl.classList.remove('bg-dark', 'text-light');
                    outputEl.style.background = 'none';
                    outputEl.style.padding = '0';
                }
            })
            .catch(function (err) {
                alert('Apply request failed: ' + err);
            })
            .finally(function () {
                applyBtn.disabled = false;
                applyBtn.innerHTML = '<i class="bi bi-play-fill"></i> Apply Now';
            });
        }

        function patchDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Comparing...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("CompareToDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');
                var titleEl = document.getElementById('deviceResultModalLabel');

                titleEl.textContent = 'Patch Device: ' + configType;
                resetModal();

                if (!data.success) {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else if (data.isMatch) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Already in sync — all <strong>' + data.matchedCount + '</strong> line(s) match on <strong>' + data.deviceName + '</strong>. Nothing to patch.</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else if (data.missingFromDevice.length === 0 && data.extraOnDevice.length === 0) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Config is in sync on <strong>' + data.deviceName + '</strong>.</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else {
                    var summary = [];
                    if (data.missingFromDevice.length > 0) summary.push('<strong>' + data.missingFromDevice.length + '</strong> line(s) to add');
                    if (data.extraOnDevice.length > 0) summary.push('<strong>' + data.extraOnDevice.length + '</strong> line(s) to remove');
                    statusEl.innerHTML = '<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Patch will sync <strong>' + data.deviceName + '</strong>: ' + summary.join(' and ') + '. Review below and click <strong>Patch Now</strong> to execute.</div>';

                    var details = '';
                    if (data.missingFromDevice.length > 0) {
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-plus-circle"></i> Lines to add (' + data.missingFromDevice.length + '):</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#6bff6b;">';
                        for (var i = 0; i < data.missingFromDevice.length; i++) {
                            details += data.missingFromDevice[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    if (data.extraOnDevice.length > 0) {
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Lines to remove (' + data.extraOnDevice.length + '):</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#ff6b6b;">';
                        for (var i = 0; i < data.extraOnDevice.length; i++) {
                            details += data.extraOnDevice[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    outputEl.innerHTML = details;
                    outputEl.style.display = '';
                    outputEl.classList.remove('bg-dark', 'text-light');
                    outputEl.style.background = 'none';
                    outputEl.style.padding = '0';

                    _pendingPatchConfigType = configType;
                    document.getElementById('patchNowBtn').classList.remove('d-none');
                }

                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) {
                alert('Request failed: ' + err);
            })
            .finally(function () {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        function executePatch() {
            var configType = _pendingPatchConfigType;
            if (!configType) return;

            var patchBtn = document.getElementById('patchNowBtn');
            patchBtn.disabled = true;
            patchBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Patching...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("PatchDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');

                patchBtn.classList.add('d-none');
                _pendingPatchConfigType = null;

                if (!data.success) {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Patch failed on <strong>' + configType + '</strong></div>';
                    outputEl.className = 'p-2 rounded mt-1';
                    outputEl.style.background = '#1a1a2e';
                    outputEl.style.color = '#ff6b6b';
                    outputEl.style.maxHeight = '400px';
                    outputEl.style.overflow = 'auto';
                    outputEl.style.whiteSpace = 'pre-wrap';
                    outputEl.textContent = data.output;
                    outputEl.style.display = '';
                } else if (data.patched === false) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else {
                    var summaryParts = [];
                    if (data.addedCount > 0) summaryParts.push('added <strong>' + data.addedCount + '</strong>');
                    if (data.removedCount > 0) summaryParts.push('removed <strong>' + data.removedCount + '</strong>');
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Patch complete on <strong>' + data.deviceName + '</strong> — ' + summaryParts.join(', ') + ' line(s).</div>';

                    var details = '';
                    if (data.addedLines && data.addedLines.length > 0) {
                        details += '<div class="mt-2"><strong class="text-success"><i class="bi bi-plus-circle"></i> Added:</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:150px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#6bff6b;">';
                        for (var i = 0; i < data.addedLines.length; i++) {
                            details += data.addedLines[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    if (data.removedLines && data.removedLines.length > 0) {
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-dash-circle"></i> Removed:</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:150px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#ff6b6b;">';
                        for (var i = 0; i < data.removedLines.length; i++) {
                            details += data.removedLines[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    if (data.transcript) {
                        details += '<div class="mt-2"><a class="text-info" data-bs-toggle="collapse" href="#patchTranscript" role="button" aria-expanded="false"><i class="bi bi-terminal"></i> Session transcript — click to expand</a>';
                        details += '<div class="collapse" id="patchTranscript"><pre class="p-2 rounded mt-1 mb-0" style="max-height:250px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#b0b0b0;">';
                        details += data.transcript.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                        details += '</pre></div></div>';
                    }
                    outputEl.innerHTML = details;
                    outputEl.style.display = details ? '' : 'none';
                    outputEl.classList.remove('bg-dark', 'text-light');
                    outputEl.style.background = 'none';
                    outputEl.style.padding = '0';
                }
            })
            .catch(function (err) {
                alert('Patch request failed: ' + err);
            })
            .finally(function () {
                patchBtn.disabled = false;
                patchBtn.innerHTML = '<i class="bi bi-play-fill"></i> Patch Now';
            });
        }

        function removeFromDevice(configType) {
            var btn = event.currentTarget;
            var originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Loading...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("PreviewRemoveFromDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');
                var titleEl = document.getElementById('deviceResultModalLabel');

                titleEl.textContent = 'Remove from Device: ' + configType;
                resetModal();

                if (!data.success) {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-exclamation-triangle-fill"></i> <strong>WARNING:</strong> This will remove <strong>' + data.removeCount + '</strong> backout line(s) from <strong>' + data.deviceName + '</strong>. This action cannot be undone. Review below and click <strong>Remove Now</strong> to execute.</div>';

                    var details = '<div class="mt-2"><strong class="text-danger"><i class="bi bi-trash"></i> Lines to remove (' + data.removeCount + '):</strong>';
                    details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:300px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#ff6b6b;">';
                    for (var i = 0; i < data.removeLines.length; i++) {
                        details += data.removeLines[i] + '\n';
                    }
                    details += '</pre></div>';

                    outputEl.innerHTML = details;
                    outputEl.style.display = '';
                    outputEl.classList.remove('bg-dark', 'text-light');
                    outputEl.style.background = 'none';
                    outputEl.style.padding = '0';

                    _pendingRemoveConfigType = configType;
                    document.getElementById('removeNowBtn').classList.remove('d-none');
                }

                new bootstrap.Modal(document.getElementById('deviceResultModal')).show();
            })
            .catch(function (err) {
                alert('Request failed: ' + err);
            })
            .finally(function () {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        function executeRemove() {
            var configType = _pendingRemoveConfigType;
            if (!configType) return;

            var removeBtn = document.getElementById('removeNowBtn');
            removeBtn.disabled = true;
            removeBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Removing...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var tenantGuid = '@ViewData["TenantGuid"]';

            fetch('@Url.Action("RemoveFromDevice", "Tenants")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'tenantGuid=' + encodeURIComponent(tenantGuid) + '&configType=' + encodeURIComponent(configType)
            })
            .then(function (response) { return response.json(); })
            .then(function (data) {
                var statusEl = document.getElementById('deviceResultStatus');
                var outputEl = document.getElementById('deviceResultOutput');

                removeBtn.classList.add('d-none');
                _pendingRemoveConfigType = null;

                if (!data.success) {
                    statusEl.innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Remove failed on <strong>' + configType + '</strong></div>';
                    outputEl.className = 'p-2 rounded mt-1';
                    outputEl.style.background = '#1a1a2e';
                    outputEl.style.color = '#ff6b6b';
                    outputEl.style.maxHeight = '400px';
                    outputEl.style.overflow = 'auto';
                    outputEl.style.whiteSpace = 'pre-wrap';
                    outputEl.textContent = data.output;
                    outputEl.style.display = '';
                } else if (data.removed === false) {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> ' + data.output + '</div>';
                    outputEl.textContent = '';
                    outputEl.style.display = 'none';
                } else {
                    statusEl.innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> Successfully removed <strong>' + data.removedCount + '</strong> line(s) from <strong>' + data.deviceName + '</strong>.</div>';

                    var details = '';
                    if (data.removedLines && data.removedLines.length > 0) {
                        details += '<div class="mt-2"><strong class="text-danger"><i class="bi bi-trash"></i> Removed:</strong>';
                        details += '<pre class="p-2 rounded mt-1 mb-0" style="max-height:200px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#ff6b6b;">';
                        for (var i = 0; i < data.removedLines.length; i++) {
                            details += data.removedLines[i] + '\n';
                        }
                        details += '</pre></div>';
                    }
                    if (data.transcript) {
                        details += '<div class="mt-2"><a class="text-info" data-bs-toggle="collapse" href="#removeTranscript" role="button" aria-expanded="false"><i class="bi bi-terminal"></i> Session transcript — click to expand</a>';
                        details += '<div class="collapse" id="removeTranscript"><pre class="p-2 rounded mt-1 mb-0" style="max-height:250px; overflow:auto; white-space:pre-wrap; background:#1a1a2e; color:#b0b0b0;">';
                        details += data.transcript.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                        details += '</pre></div></div>';
                    }
                    outputEl.innerHTML = details;
                    outputEl.style.display = details ? '' : 'none';
                    outputEl.classList.remove('bg-dark', 'text-light');
                    outputEl.style.background = 'none';
                    outputEl.style.padding = '0';
                }
            })
            .catch(function (err) {
                alert('Remove request failed: ' + err);
            })
            .finally(function () {
                removeBtn.disabled = false;
                removeBtn.innerHTML = '<i class="bi bi-trash"></i> Remove Now';
            });
        }

        function copyToClipboard(configType, btn) {
            var textarea = document.getElementById(configType);
            if (textarea) {
                navigator.clipboard.writeText(textarea.value).then(function () {
                    var original = btn.textContent;
                    btn.textContent = '\u2714 Copied!';
                    btn.classList.replace('btn-primary', 'btn-success');
                    setTimeout(function () {
                        btn.textContent = original;
                        btn.classList.replace('btn-success', 'btn-primary');
                    }, 1500);
                });
            }
        }

        function downloadMail() {
            var mailBody = document.getElementById('eMailHTML');
            if (!mailBody) return;

            var emailTo = '@Html.Raw(contacts)';
            var emailSubject = 'Your PathLab Environment is Ready!';
            var emailCont = 'To: ' + emailTo + '\n'
                + 'Subject: ' + emailSubject + '\n'
                + 'X-Unsent: 1\n'
                + 'Content-Type: text/html\n'
                + '\n'
                + mailBody.value
                + '\n';

            var blob = new Blob([emailCont], { type: 'text/plain' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = emailSubject + '.eml';
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }
    </script>
}
