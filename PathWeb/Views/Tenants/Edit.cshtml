@model PathWeb.Models.Tenant
@{
    ViewData["Title"] = $"Edit Tenant: {Model.TenantName}";
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
</div>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="TenantGuid" />
    <input type="hidden" asp-for="Lab" />
    <input type="hidden" asp-for="TenantId" />
    <input type="hidden" asp-for="AssignedDate" />
    <input type="hidden" asp-for="AssignedBy" />

    <div class="d-flex gap-2 mb-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Details" asp-route-id="@Model.TenantGuid" class="btn btn-secondary">Cancel</a>
    </div>
    <input type="hidden" asp-for="LastUpdateDate" />
    <input type="hidden" asp-for="LastUpdateBy" />
    <input type="hidden" asp-for="DeletedDate" />
    <input type="hidden" asp-for="DeletedBy" />
    <input type="hidden" asp-for="WorkItemId" />

    <!-- Basic Information -->
    <div class="card mb-3">
        <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseBasic" role="button" aria-expanded="true">
            Basic Information
        </div>
        <div class="collapse show" id="collapseBasic">
            <div class="card-body">
                <div class="mb-3 row">
                    <label class="col-md-3 col-form-label fw-bold">Tenant Name</label>
                    <div class="col-md-9">
                        <input class="form-control" value="@Model.TenantName" readonly />
                    </div>
                </div>
                <input type="hidden" asp-for="TenantVersion" />
                <div class="mb-3 row">
                    <label asp-for="NinjaOwner" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="NinjaOwner" asp-items="@ViewBag.Ninjas" class="form-select">
                            <option value="">- select Ninja Owner -</option>
                        </select>
                        <span asp-validation-for="NinjaOwner" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Contacts" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <input asp-for="Contacts" class="form-control" placeholder="email@microsoft.com;email2@microsoft.com" />
                        <span asp-validation-for="Contacts" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="ReturnDate" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <input asp-for="ReturnDate" class="form-control" type="date" />
                        <span asp-validation-for="ReturnDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Usage" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <textarea asp-for="Usage" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Usage" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Azure Information -->
    <div class="card mb-3">
        <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseAzure" role="button" aria-expanded="true">
            Azure Information
        </div>
        <div class="collapse show" id="collapseAzure">
            <div class="card-body">
                <div class="mb-3 row">
                    <label asp-for="AzureRegion" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="AzureRegion" asp-items="@ViewBag.Regions" class="form-select">
                            <option value="">- select Azure Region -</option>
                        </select>
                        <span asp-validation-for="AzureRegion" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Ersku" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="Ersku" asp-items="@ViewBag.ErSkus" class="form-select"></select>
                        <span asp-validation-for="Ersku" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Erspeed" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="Erspeed" asp-items="@ViewBag.ErSpeeds" class="form-select"></select>
                        <span asp-validation-for="Erspeed" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="EruplinkPort" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="EruplinkPort" asp-items="@ViewBag.ErUplinksSea" class="form-select"></select>
                        <span asp-validation-for="EruplinkPort" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="PvtPeering" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="PvtPeering" asp-items="@ViewBag.BoolOptions" class="form-select"></select>
                        <span asp-validation-for="PvtPeering" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="ErgatewaySize" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="ErgatewaySize" asp-items="@ViewBag.ErGateways" class="form-select"></select>
                        <span asp-validation-for="ErgatewaySize" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="ErfastPath" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="ErfastPath" asp-items="@ViewBag.BoolOptions" class="form-select"></select>
                        <span asp-validation-for="ErfastPath" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Msftpeering" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="Msftpeering" asp-items="@ViewBag.BoolOptions" class="form-select"></select>
                        <span asp-validation-for="Msftpeering" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Msfttags" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <input asp-for="Msfttags" class="form-control" />
                        <span asp-validation-for="Msfttags" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Skey" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <input asp-for="Skey" class="form-control" />
                        <span asp-validation-for="Skey" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- VPN Information -->
    <div class="card mb-3">
        <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseVpn" role="button" aria-expanded="true">
            VPN Information
        </div>
        <div class="collapse show" id="collapseVpn">
            <div class="card-body">
                <div class="mb-3 row">
                    <label asp-for="Vpngateway" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="Vpngateway" asp-items="@ViewBag.VpnGateways" class="form-select"></select>
                        <span asp-validation-for="Vpngateway" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Vpnbgp" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="Vpnbgp" asp-items="@ViewBag.BoolOptions" class="form-select"></select>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Vpnconfig" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="Vpnconfig" asp-items="@ViewBag.VpnConfigs" class="form-select"></select>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="VpnendPoint" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <input asp-for="VpnendPoint" class="form-control" />
                        <span asp-validation-for="VpnendPoint" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- VM Information -->
    <div class="card mb-3">
        <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseVm" role="button" aria-expanded="true">
            VM Information
        </div>
        <div class="collapse show" id="collapseVm">
            <div class="card-body">
                <div class="mb-3 row">
                    <label asp-for="AddressFamily" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="AddressFamily" asp-items="@ViewBag.IpVersions" class="form-select"></select>
                        <span asp-validation-for="AddressFamily" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="AzVm1" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="AzVm1" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="AzVm2" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="AzVm2" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="AzVm3" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="AzVm3" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="AzVm4" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="AzVm4" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="LabVm1" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="LabVm1" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                        <span asp-validation-for="LabVm1" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="LabVm2" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="LabVm2" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                        <span asp-validation-for="LabVm2" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="LabVm3" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="LabVm3" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                        <span asp-validation-for="LabVm3" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="LabVm4" class="col-md-3 col-form-label fw-bold"></label>
                    <div class="col-md-9">
                        <select asp-for="LabVm4" asp-items="@ViewBag.VmOsList" class="form-select"></select>
                        <span asp-validation-for="LabVm4" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Information (collapsed by default) -->
    <div class="card mb-3">
        <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseAdmin" role="button" aria-expanded="false">
            Additional Information
        </div>
        <div class="collapse" id="collapseAdmin">
            <div class="card-body">
                <table class="table table-hover mb-0">
                    <tr><th style="width:200px">Tenant GUID</th><td>@Model.TenantGuid</td></tr>
                    <tr><th>Tenant Version</th><td>@Model.TenantVersion</td></tr>
                    <tr><th>Assigned Date</th><td>@Model.AssignedDate.ToString("u")</td></tr>
                    <tr><th>Assigned By</th><td>@Model.AssignedBy</td></tr>
                    <tr><th>Last Update</th><td>@Model.LastUpdateDate.ToString("u")</td></tr>
                    <tr><th>Updated By</th><td>@Model.LastUpdateBy</td></tr>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Details" asp-route-id="@Model.TenantGuid" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
