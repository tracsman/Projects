@model PathWeb.Models.Tenant
@{
    ViewData["Title"] = $"Tenant Details: {Model.TenantName}";
    byte authLevel = (byte)(ViewContext.HttpContext.Items["AuthLevel"] ?? (byte)0);
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
</div>

<div class="d-flex gap-2 mb-3">
    @if (authLevel >= 8)
    {
        <a asp-action="Edit" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Edit</a>
        <a asp-action="Release" asp-route-id="@Model.TenantGuid" class="btn btn-danger">Release</a>
        <a asp-action="ConfigGen" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Create Config</a>
    }
    <a asp-action="Config" asp-route-id="@Model.TenantGuid" class="btn btn-primary">View Config</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

<!-- Basic Information -->
<div class="card mb-3">
    <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseBasic" role="button" aria-expanded="true">
        Basic Information
    </div>
    <div class="collapse show" id="collapseBasic">
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Tenant Name</th><td>@Model.TenantName</td></tr>
            <tr><th>Ninja Owner</th><td>@ViewData["NinjaDisplayName"] (@Model.NinjaOwner)</td></tr>
            <tr><th>Contact(s)</th><td>@Model.Contacts</td></tr>
            <tr><th>Return Date</th><td>@Model.ReturnDate.ToString("d")</td></tr>
            <tr><th>Usage</th><td>@Model.Usage</td></tr>
        </table>
    </div>
    </div>
</div>

<!-- Azure / ExpressRoute Information -->
<div class="card mb-3">
    <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseAzure" role="button" aria-expanded="true">
        Azure / ExpressRoute Information
    </div>
    <div class="collapse show" id="collapseAzure">
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Azure Region</th><td>@Model.AzureRegion</td></tr>
            <tr><th>ER SKU</th><td>@Model.Ersku</td></tr>
            <tr><th>ER Speed</th><td>@(Model.Erspeed >= 1000 ? $"{Model.Erspeed / 1000} Gbps" : $"{Model.Erspeed} Mbps")</td></tr>
            <tr><th>Uplink Port</th><td>@Model.EruplinkPort</td></tr>
            <tr><th>Private Peering</th><td>@(Model.PvtPeering == true ? "Enabled" : "Not Enabled")</td></tr>
            <tr><th>ER Gateway Size</th><td>@Model.ErgatewaySize</td></tr>
            <tr><th>ER Fast Path</th><td>@(Model.ErfastPath == true ? "Enabled" : "Not Enabled")</td></tr>
            <tr><th>MSFT Peering</th><td>@(Model.Msftpeering == true ? "Enabled" : "Not Enabled")</td></tr>
            <tr><th>MSFT P2P</th><td>@(string.IsNullOrEmpty(Model.Msftp2p) ? Html.Raw("<i>empty</i>") : Model.Msftp2p)</td></tr>
            <tr><th>MSFT NAT(s)</th><td>@(string.IsNullOrEmpty(Model.Msftadv) ? Html.Raw("<i>empty</i>") : Model.Msftadv)</td></tr>
            <tr><th>BGP Communities</th><td>@(string.IsNullOrEmpty(Model.Msfttags) ? Html.Raw("<i>empty</i>") : Model.Msfttags)</td></tr>
            <tr><th>Service Key</th><td>@(Model.Skey.HasValue ? Model.Skey.ToString() : Html.Raw("<i>empty</i>"))</td></tr>
        </table>
    </div>
    </div>
</div>

<!-- VPN Information -->
<div class="card mb-3">
    <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseVpn" role="button" aria-expanded="true">
        VPN Information
    </div>
    <div class="collapse show" id="collapseVpn">
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">VPN Gateway Size</th><td>@Model.Vpngateway</td></tr>
            <tr><th>BGP</th><td>@(Model.Vpnbgp == true ? "Enabled" : "Not Enabled")</td></tr>
            <tr><th>VPN Config</th><td>@Model.Vpnconfig</td></tr>
            <tr><th>VPN End Point(s)</th><td>@(string.IsNullOrEmpty(Model.VpnendPoint) ? Html.Raw("<i>empty</i>") : Model.VpnendPoint)</td></tr>
        </table>
    </div>
    </div>
</div>

<!-- VM Information -->
<div class="card mb-3">
    <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseVm" role="button" aria-expanded="true">
        VM Information
    </div>
    <div class="collapse show" id="collapseVm">
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Address Family</th><td>@Model.AddressFamily</td></tr>
            <tr><th>Azure VM 1</th><td>@Model.AzVm1</td></tr>
            <tr><th>Azure VM 2</th><td>@Model.AzVm2</td></tr>
            <tr><th>Azure VM 3</th><td>@Model.AzVm3</td></tr>
            <tr><th>Azure VM 4</th><td>@Model.AzVm4</td></tr>
            <tr><th>On-prem VM 1</th><td>@Model.LabVm1</td></tr>
            <tr><th>On-prem VM 2</th><td>@Model.LabVm2</td></tr>
            <tr><th>On-prem VM 3</th><td>@Model.LabVm3</td></tr>
            <tr><th>On-prem VM 4</th><td>@Model.LabVm4</td></tr>
        </table>
    </div>
    </div>
</div>

<!-- Administrative Information -->
<div class="card mb-3">
    <div class="card-header fw-bold" data-bs-toggle="collapse" data-bs-target="#collapseAdmin" role="button" aria-expanded="false">
        Administrative Information
    </div>
    <div class="collapse" id="collapseAdmin">
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Tenant GUID</th><td>@Model.TenantGuid</td></tr>
            <tr><th>Tenant Version</th><td>@Model.TenantVersion</td></tr>
            <tr><th>Work Item ID</th><td>@if (Model.WorkItemId.HasValue && Model.WorkItemId > 0)
                    {
                        var adoOrg = ViewContext.HttpContext.RequestServices.GetRequiredService<IConfiguration>()["AzureDevOps:OrgUrl"];
                        var adoProject = ViewContext.HttpContext.RequestServices.GetRequiredService<IConfiguration>()["AzureDevOps:Project"];
                        <a href="@adoOrg/@adoProject/_workitems/edit/@Model.WorkItemId" target="_blank">@Model.WorkItemId</a>
                    }
                    else
                    {
                        <i>none</i>
                    }</td></tr>
            <tr><th>Assigned Date</th><td>@Model.AssignedDate.ToString("u")</td></tr>
            <tr><th>Assigned By</th><td>@Model.AssignedBy</td></tr>
            <tr><th>Last Update</th><td>@Model.LastUpdateDate.ToString("u")</td></tr>
            <tr><th>Updated By</th><td>@Model.LastUpdateBy</td></tr>
        </table>
    </div>
    </div>
</div>

<hr />
<div class="d-flex gap-2">
    @if (authLevel >= 8)
    {
        <a asp-action="Edit" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Edit</a>
        <a asp-action="Release" asp-route-id="@Model.TenantGuid" class="btn btn-danger">Release</a>
        <a asp-action="ConfigGen" asp-route-id="@Model.TenantGuid" class="btn btn-primary">Create Config</a>
    }
    <a asp-action="Config" asp-route-id="@Model.TenantGuid" class="btn btn-primary">View Config</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
