@model PathWeb.Models.PublicIp
@{
    ViewData["Title"] = "Edit Address Prefix";
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
</div>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="RangeId" />

            <div class="mb-3 row">
                <label asp-for="Range" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="Range" class="form-control" readonly />
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="RangeType" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="RangeType" class="form-control" readonly />
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="Lab" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="Lab" class="form-control" readonly />
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="Device" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="Device" class="form-control" />
                    <span asp-validation-for="Device" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="Purpose" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="Purpose" class="form-control" />
                    <span asp-validation-for="Purpose" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="TenantGuid" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="TenantGuid" class="form-control" />
                    <span asp-validation-for="TenantGuid" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="TenantId" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="TenantId" class="form-control" />
                    <span asp-validation-for="TenantId" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="AssignedDate" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="AssignedDate" class="form-control" type="datetime-local"
                           value="@(Model.AssignedDate?.ToString("yyyy-MM-ddTHH:mm:ss"))" />
                    <span asp-validation-for="AssignedDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 row">
                <label asp-for="AssignedBy" class="col-md-3 col-form-label fw-bold"></label>
                <div class="col-md-9">
                    <input asp-for="AssignedBy" class="form-control" />
                    <span asp-validation-for="AssignedBy" class="text-danger"></span>
                </div>
            </div>

            <div class="offset-md-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
