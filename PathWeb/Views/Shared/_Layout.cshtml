<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PathWeb</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PathWeb.styles.css" asp-append-version="true" />
    <script>
        // Apply theme immediately to prevent flash of wrong theme
        (function() {
            var m = document.cookie.match(/(?:^|;\s*)theme=([^;]*)/);
            if (m && m[1] === 'dark') {
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">PathWeb</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @{
                        byte navAuthLevel = (byte)(ViewContext.HttpContext.Items["AuthLevel"] ?? (byte)0);
                    }
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Requests" asp-action="Create">Request a Lab</a>
                        </li>
                        @if (navAuthLevel >= 6)
                        {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tenants" asp-action="Index">Tenants</a>
                        </li>
                        }
                        @if (navAuthLevel >= 8)
                        {
                            var db = ViewContext.HttpContext.RequestServices.GetRequiredService<PathWeb.Data.LabConfigContext>();
                            var pendingCount = db.TenantRequests.Count(r => r.Status == "Pending");
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Admin@(pendingCount > 0 ? $" ({pendingCount})" : "")
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Requests" asp-action="Queue">Tenant Requests</a></li>
                                @if (navAuthLevel >= 11)
                                {
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Devices" asp-action="Index">Devices</a></li>
                                <li><a class="dropdown-item" asp-controller="Addresses" asp-action="Index">IP Addresses</a></li>
                                }
                                @if (navAuthLevel >= 14)
                                {
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">Users</a></li>
                                <li><a class="dropdown-item" asp-controller="ToolTips" asp-action="Index">Tooltips</a></li>
                                }
                            </ul>
                        </li>
                        }
                        @if (navAuthLevel >= 1)
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                About
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="About" asp-action="Index">...this Site</a></li>
                                <li><a class="dropdown-item" asp-controller="About" asp-action="Lab">...the Physical Lab</a></li>
                                <li><a class="dropdown-item" asp-controller="About" asp-action="Tenant">...the Logical Tenant</a></li>
                                <li><a class="dropdown-item" asp-controller="About" asp-action="Progress">...Site Dev Progress</a></li>
                            </ul>
                        </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                    <button id="theme-toggle" class="theme-toggle" title="Toggle dark mode">🌙</button>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-@TempData["MessageLevel"] mt-3">
                @TempData["Message"]
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 - PathWeb - <a asp-controller="Home" asp-action="Privacy">Privacy</a></span>
            <span>Build: @System.IO.File.GetLastWriteTime(typeof(Program).Assembly.Location).ToString("yyyy-MM-dd HH:mm:ss")</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll('[data-bs-toggle="popover"]').forEach(function (el) {
            new bootstrap.Popover(el);
        });
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
