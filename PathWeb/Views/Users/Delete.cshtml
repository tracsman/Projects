@model PathWeb.Models.User
@{
    ViewData["Title"] = "Delete User";
}

<div class="container">
    <h1>Delete User</h1>
    <hr />

    <h3>Are you sure you want to delete this user?</h3>

    <div class="card mt-3" style="max-width: 400px;">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-5">User Name</dt>
                <dd class="col-sm-7">@Model.UserName</dd>

                <dt class="col-sm-5">Name</dt>
                <dd class="col-sm-7">@Model.Name</dd>

                <dt class="col-sm-5">Auth Level</dt>
                <dd class="col-sm-7">@Model.AuthLevel</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="UserId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
