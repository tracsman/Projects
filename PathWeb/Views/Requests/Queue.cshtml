@model IEnumerable<PathWeb.Models.TenantRequest>
@{
    ViewData["Title"] = "Pending Lab Requests";
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
    <p>There are <strong>@Model.Count()</strong> pending request(s) awaiting review.</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No pending requests at this time.</div>
}
else
{
    <table class="table table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Requested By</th>
                <th class="text-center">Lab</th>
                <th>Usage</th>
                <th class="text-center">Requested</th>
                <th class="text-center">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(((Dictionary<string, string>)ViewBag.UserNames).GetValueOrDefault(item.RequestedBy, item.RequestedBy))</td>
                    <td class="text-center">@item.Lab</td>
                    <td>@(item.Usage.Length > 60 ? item.Usage[..60] + "..." : item.Usage)</td>
                    <td class="text-center">@item.RequestedDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-center">
                        <a asp-action="Review" asp-route-id="@item.RequestId">Review</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
