@model PathWeb.Models.TenantRequest
@{
    ViewData["Title"] = "Request Details";
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <h2>@ViewData["Title"]</h2>
</div>

@if (Model.Status == "Rejected" && !string.IsNullOrEmpty(Model.ReviewNotes))
{
    <div class="alert alert-danger">
        <strong>Rejection Reason:</strong> @Model.ReviewNotes
    </div>
}
@if (Model.Status == "Approved" && Model.TenantGuid.HasValue)
{
    <div class="alert alert-success">
        <strong>Approved!</strong> Tenant created:
        <a asp-controller="Tenants" asp-action="Details" asp-route-id="@Model.TenantGuid">View Tenant</a>
    </div>
}

@{
    var badgeClass = Model.Status switch
    {
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<!-- Request Info -->
<div class="card mb-3">
    <div class="card-header fw-bold">Request Info</div>
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Status</th><td><span class="badge @badgeClass">@Model.Status</span></td></tr>
            <tr><th>Requested By</th><td>@(((Dictionary<string, string>)ViewBag.UserNames).GetValueOrDefault(Model.RequestedBy, Model.RequestedBy))</td></tr>
            <tr><th>Requested</th><td>@Model.RequestedDate.ToString("u")</td></tr>
            @if (Model.ReviewedDate.HasValue)
            {
                <tr><th>Reviewed By</th><td>@(((Dictionary<string, string>)ViewBag.UserNames).GetValueOrDefault(Model.ReviewedBy ?? "", Model.ReviewedBy ?? ""))</td></tr>
                <tr><th>Reviewed</th><td>@Model.ReviewedDate.Value.ToString("u")</td></tr>
            }
        </table>
    </div>
</div>

<!-- Basic Information -->
<div class="card mb-3">
    <div class="card-header fw-bold">Basic Information</div>
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Lab</th><td>@Model.Lab</td></tr>
            <tr><th>Contact(s)</th><td>@Model.Contacts</td></tr>
            <tr><th>Usage</th><td>@Model.Usage</td></tr>
        </table>
    </div>
</div>

<!-- Azure / ExpressRoute -->
<div class="card mb-3">
    <div class="card-header fw-bold">Azure / ExpressRoute</div>
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Azure Region</th><td>@Model.AzureRegion</td></tr>
            <tr><th>ER SKU</th><td>@Model.Ersku</td></tr>
            <tr><th>ER Speed</th><td>@Model.Erspeed</td></tr>
            <tr><th>Uplink Port</th><td>@Model.EruplinkPort</td></tr>
            <tr><th>Private Peering</th><td>@(Model.PvtPeering == true ? "Enabled" : "Not Enabled")</td></tr>
            <tr><th>ER Gateway Size</th><td>@Model.ErgatewaySize</td></tr>
            <tr><th>ER Fast Path</th><td>@(Model.ErfastPath == true ? "Enabled" : "Not Enabled")</td></tr>
            <tr><th>MSFT Peering</th><td>@(Model.Msftpeering == true ? "Enabled" : "Not Enabled")</td></tr>
        </table>
    </div>
</div>

<!-- VPN -->
<div class="card mb-3">
    <div class="card-header fw-bold">VPN Information</div>
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">VPN Gateway</th><td>@Model.Vpngateway</td></tr>
            <tr><th>VPN BGP</th><td>@(Model.Vpnbgp == true ? "Enabled" : "Not Enabled")</td></tr>
            <tr><th>VPN Config</th><td>@Model.Vpnconfig</td></tr>
        </table>
    </div>
</div>

<!-- VMs -->
<div class="card mb-3">
    <div class="card-header fw-bold">VM Information</div>
    <div class="card-body">
        <table class="table table-hover mb-0">
            <tr><th style="width:200px">Address Family</th><td>@Model.AddressFamily</td></tr>
            <tr><th>Azure VM 1</th><td>@Model.AzVm1</td></tr>
            <tr><th>Azure VM 2</th><td>@Model.AzVm2</td></tr>
            <tr><th>Azure VM 3</th><td>@Model.AzVm3</td></tr>
            <tr><th>Azure VM 4</th><td>@Model.AzVm4</td></tr>
            <tr><th>Lab VM 1</th><td>@Model.LabVm1</td></tr>
            <tr><th>Lab VM 2</th><td>@Model.LabVm2</td></tr>
            <tr><th>Lab VM 3</th><td>@Model.LabVm3</td></tr>
            <tr><th>Lab VM 4</th><td>@Model.LabVm4</td></tr>
        </table>
    </div>
</div>

<hr />
<div class="d-flex gap-2">
    <a asp-action="Index" class="btn btn-secondary">Back to My Requests</a>
</div>
