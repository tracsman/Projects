@model IEnumerable<PathWeb.Models.Device>
@{
    ViewData["Title"] = "Lab Devices";
    byte authLevel = (byte)(ViewContext.HttpContext.Items["AuthLevel"] ?? (byte)0);
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2>@ViewData["Title"]</h2>
            <p>This is a list of all lab devices (routers, switches, firewalls, and servers) in our database.</p>
            <p>With the appropriate permission level, you can update management IPs, OS, and issue notes.</p>
            <p class="mb-0"><strong>Note:</strong> This is a fixed list, you can't add or delete rows or update the device name, type, or lab assignment.</p>
        </div>
        @if (authLevel >= 12)
        {
            <div class="d-flex flex-column gap-2">
                <a asp-action="RunCommand" class="btn btn-primary">Run Command</a>
                <form method="post" asp-action="PopulateOs">
                    <button type="submit" class="btn btn-outline-secondary w-100"
                            onclick="return confirm('This will SSH into all network devices to detect their OS version and save the results to the Devices table in SQL. Continue?')">
                        Update OS Versions
                    </button>
                </form>
            </div>
        }
    </div>
</div>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th class="text-center">
                <a asp-action="Index" asp-route-sortOrder="@ViewData["LabSortParm"]" class="text-light text-decoration-none" title="Sort by Lab">Lab</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" class="text-light text-decoration-none" title="Sort by Name">Name</a>
            </th>
            <th class="text-center">
                <a asp-action="Index" asp-route-sortOrder="@ViewData["TypeSortParm"]" class="text-light text-decoration-none" title="Sort by Type">Type</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["OsSortParm"]" class="text-light text-decoration-none" title="Sort by OS">OS</a>
            </th>
            <th class="text-center">
                <a asp-action="Index" asp-route-sortOrder="@ViewData["InServiceSortParm"]" class="text-light text-decoration-none" title="Sort by In Service status">In Service</a>
            </th>
            <th class="text-center">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.InService ? "" : "table-warning")">
                <td class="text-center">@item.Lab</td>
                <td>@item.Name</td>
                <td class="text-center">@item.Type</td>
                <td>@item.Os</td>
                <td class="text-center">@(item.InService ? "Yes" : "No")</td>
                <td class="text-center">
                    @if (authLevel >= 12)
                    {
                        <a asp-action="Edit" asp-route-id="@item.DeviceId">Edit</a>
                        <span>|</span>
                    }
                    <a asp-action="Details" asp-route-id="@item.DeviceId">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
