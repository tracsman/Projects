@model IEnumerable<PathWeb.Models.Device>
@{
    ViewData["Title"] = "Lab Devices";
    byte authLevel = (byte)(ViewContext.HttpContext.Items["AuthLevel"] ?? (byte)0);
}

<div class="container bg-body-tertiary rounded p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2>@ViewData["Title"]</h2>
            <p>This is a list of all lab devices (routers, switches, firewalls, and servers) in our database.</p>
            <p>With the appropriate permission level, you can update management IPs, OS, and issue notes.</p>
            <p class="mb-0"><strong>Note:</strong> This is a fixed list, you can't add or delete rows or update the device name, type, or lab assignment.</p>
        </div>
        @if (authLevel >= 12)
        {
            <div class="d-flex flex-column gap-2">
                <a asp-action="RunCommand" class="btn btn-primary">Run Command</a>
                <form method="post" asp-action="PopulateOs">
                    <button type="submit" class="btn btn-outline-secondary w-100"
                            onclick="return confirm('This will SSH into all network devices to detect their OS version and save the results to the Devices table in SQL. Continue?')">
                        Update OS Versions
                    </button>
                </form>
            </div>
        }
    </div>
</div>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th class="text-center">
                <a asp-action="Index" asp-route-sortOrder="@ViewData["LabSortParm"]" class="text-light text-decoration-none" title="Sort by Lab">Lab</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" class="text-light text-decoration-none" title="Sort by Name">Name</a>
            </th>
            <th class="text-center">
                <a asp-action="Index" asp-route-sortOrder="@ViewData["TypeSortParm"]" class="text-light text-decoration-none" title="Sort by Type">Type</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["OsSortParm"]" class="text-light text-decoration-none" title="Sort by OS">OS</a>
            </th>
            <th class="text-center">
                <a asp-action="Index" asp-route-sortOrder="@ViewData["InServiceSortParm"]" class="text-light text-decoration-none" title="Sort by In Service status">In Service</a>
            </th>
            <th class="text-center">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.InService ? "" : "table-warning")">
                <td class="text-center">@item.Lab</td>
                <td>@item.Name</td>
                <td class="text-center">@item.Type</td>
                <td>@item.Os</td>
                <td class="text-center">@(item.InService ? "Yes" : "No")</td>
                <td class="text-center">
                    @if (authLevel >= 12)
                    {
                        <a asp-action="Edit" asp-route-id="@item.DeviceId">Edit</a>
                        <span>|</span>
                    }
                    <a asp-action="Details" asp-route-id="@item.DeviceId">Details</a>
                    @if (!string.IsNullOrEmpty(item.MgmtIpv4))
                    {
                        <span>|</span>
                        <a href="#" class="validate-link" data-device-id="@item.DeviceId" data-device-name="@item.Name">Validate</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@Html.AntiForgeryToken()

<div class="modal fade" id="validateModal" tabindex="-1" aria-labelledby="validateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="validateModalLabel">Validate Device</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="validateStatus" class="mb-2"></div>
                <pre id="validateOutput" class="bg-dark text-light p-3 rounded" style="max-height:400px; overflow:auto; white-space:pre-wrap; display:none;"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.validate-link').forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                var deviceId = this.dataset.deviceId;
                var deviceName = this.dataset.deviceName;
                validateDevice(deviceId, deviceName);
            });
        });

        async function validateDevice(deviceId, deviceName) {
            document.getElementById('validateModalLabel').textContent = 'Validate: ' + deviceName;
            document.getElementById('validateStatus').innerHTML = '<div class="alert alert-info mb-0"><i class="bi bi-hourglass-split"></i> Connecting via SSH...</div>';
            document.getElementById('validateOutput').style.display = 'none';
            document.getElementById('validateOutput').textContent = '';

            var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('validateModal'));
            modal.show();

            try {
                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                var response = await fetch('@Url.Action("Validate", "Devices")?id=' + encodeURIComponent(deviceId), {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                var data = await response.json();

                if (data.success && data.checks) {
                    var icon = data.allPassed ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
                    var alertClass = data.allPassed ? 'alert-success' : 'alert-warning';
                    var html = '<div class="alert ' + alertClass + ' mb-2"><i class="bi ' + icon + '"></i> <strong>' + data.device + '</strong> (' + data.host + ') — SSH connected as Administrator</div>';
                    html += '<table class="table table-sm mb-0"><thead><tr><th>Check</th><th class="text-center">Result</th><th>Detail</th></tr></thead><tbody>';
                    for (var i = 0; i < data.checks.length; i++) {
                        var c = data.checks[i];
                        var badge = c.pass
                            ? '<span class="badge text-bg-success">Pass</span>'
                            : '<span class="badge text-bg-danger">Fail</span>';
                        html += '<tr><td>' + c.check + '</td><td class="text-center">' + badge + '</td><td><small>' + (c.detail || '') + '</small></td></tr>';
                    }
                    html += '</tbody></table>';
                    document.getElementById('validateStatus').innerHTML = html;
                } else if (data.success) {
                    document.getElementById('validateStatus').innerHTML = '<div class="alert alert-success mb-0"><i class="bi bi-check-circle-fill"></i> <strong>' + data.device + '</strong> (' + data.host + ') — show version passed</div>';
                    if (data.output) {
                        document.getElementById('validateOutput').textContent = data.output;
                        document.getElementById('validateOutput').style.display = '';
                    }
                } else {
                    document.getElementById('validateStatus').innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> <strong>' + (data.device || deviceName) + '</strong> — ' + (data.error || 'Validation failed') + '</div>';
                    if (data.output) {
                        document.getElementById('validateOutput').textContent = data.output;
                        document.getElementById('validateOutput').style.display = '';
                    }
                }
            } catch (err) {
                document.getElementById('validateStatus').innerHTML = '<div class="alert alert-danger mb-0"><i class="bi bi-x-circle-fill"></i> Request failed: ' + err + '</div>';
            }
        }
    </script>
}
